[Unit]
Description=Claude Code — boucle d'amélioration continue (mode observation, read-only)
# Aucun accès réseau pour l'observation (rsync local ~/.claude → data/raw ;
# tout le pipeline sanitize/normalize/metrics/compare est local, aucun appel
# modèle). Le 2e ExecStart (audit tokens, T1.2) fait UN appel réseau sortant :
# Telegram api.telegram.org, UNIQUEMENT si la part Opus+Fable dépasse le
# seuil. Le 3e ExecStart (drift plugins, T1.3) fait des GET read-only vers
# api.github.com et raw.githubusercontent.com (lecture marketplace.json des
# plugins installés) — détection drift uniquement, jamais d'update.

[Service]
Type=oneshot
WorkingDirectory={{ cc_improvement_lab_dir }}
Environment=CC_TOKEN_AUDIT_THRESHOLD_PCT={{ cc_improvement_token_audit_threshold_pct }}
Environment=CC_PLUGIN_DRIFT_STALE_DAYS={{ cc_improvement_plugin_drift_stale_days }}
ExecStart=/bin/bash {{ cc_improvement_lab_dir }}/prototypes/scripts/continuous-improvement.sh observe
# Audit tokens mensuel (T1.2) : part Opus+Fable du coût notionnel, alerte
# Telegram si > seuil (silence sinon). Séquentiel après l'observation
# (ExecStart= multiples = exécution en ordre, doc systemd.service(5)).
ExecStart=/bin/bash {{ cc_improvement_lab_dir }}/scripts/token_audit_notify.sh
# Drift plugins/marketplaces mensuel (T1.3) : compare chaque plugin installé
# à son marketplace amont GitHub + fraîcheur marketplace. Écrit un fichier
# inbox lab UNIQUEMENT s'il y a >=1 finding (silence sinon, anti-bruit).
# Détection-only, jamais d'auto-update.
ExecStart=/bin/bash {{ cc_improvement_lab_dir }}/scripts/plugin_drift_check.sh
Nice=19
IOSchedulingClass=idle
# Doctrine waza (REX 2026-06-05) : tout job batch borné en mémoire, OOM-kill le
# job avant d'affamer le réseau/networkd. loop_error_scan charge ~3200 JSONL.
MemoryMax={{ cc_improvement_memory_max }}
OOMScoreAdjust={{ cc_improvement_oom_score_adjust }}

# Pas de [Install] : déclenché par le timer (Type=oneshot).
