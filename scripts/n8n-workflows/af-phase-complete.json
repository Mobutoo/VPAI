      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        470,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-secret",
              "leftValue": "={{ $json.headers['x-af-secret'] }}",
              "rightValue": "={{ $env.AF_WEBHOOK_SECRET }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "respond-403",
      "name": "Respond 403",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        690,
        480
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ error: 'Forbidden', message: 'Invalid AF secret' }) }}",
        "options": {
          "responseCode": 403
        }
      }
    },
    {
      "id": "parse-phase",
      "name": "Parse Phase Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst required = ['project_name', 'phase_number', 'phase_name', 'summary'];\nconst missing = required.filter(f => !body[f] && body[f] !== 0);\nif (missing.length > 0) {\n  throw new Error(`Missing required fields: ${missing.join(', ')}`);\n}\n\nreturn [{\n  json: {\n    project_name: body.project_name,\n    phase_number: body.phase_number,\n    phase_name: body.phase_name,\n    summary: body.summary,\n    duration_min: body.duration_min || 0,\n    files_changed: body.files_changed || 0,\n    decisions: body.decisions || [],\n    timestamp: new Date().toISOString()\n  }\n}];"
      }
    },
    {
      "id": "nocodb-insert-phase-log",
      "name": "NocoDB Insert Phase Log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1350,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "http://javisi_nocodb:8080/api/v2/tables/mx5x4nb739fjld1/records",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-token",
              "value": "={{ $env.NOCODB_API_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project: $('Parse Phase Data').first().json.project_name, phase: $('Parse Phase Data').first().json.phase_number, phase_name: $('Parse Phase Data').first().json.phase_name, duration_min: $('Parse Phase Data').first().json.duration_min, files_count: $('Parse Phase Data').first().json.files_changed, decisions_count: ($('Parse Phase Data').first().json.decisions || []).length, timestamp: $('Parse Phase Data').first().json.timestamp }) }}",
        "options": {}
      }
    },
    {
      "id": "split-decisions",
      "name": "Split Decisions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2450,
        300
      ],
      "parameters": {
        "jsCode": "const parsed = $('Parse Phase Data').first().json;\nconst decisions = parsed.decisions || [];\n\nif (decisions.length === 0) {\n  return [{ json: { _skip_decisions: true, project_name: parsed.project_name, phase_number: parsed.phase_number, phase_name: parsed.phase_name, summary: parsed.summary } }];\n}\n\nreturn decisions.map((d, idx) => ({\n  json: {\n    _skip_decisions: false,\n    project_name: parsed.project_name,\n    phase_number: parsed.phase_number,\n    phase_name: parsed.phase_name,\n    decision_index: idx,\n    decision_title: d.title || d.name || `Decision ${idx + 1}`,\n    decision_rationale: d.rationale || d.description || '',\n    decision_category: d.category || 'general',\n    timestamp: parsed.timestamp\n  }\n}));"
      }
    },
    {
      "id": "check-has-decisions",
      "name": "Has Decisions?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2670,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-decisions",
              "leftValue": "={{ $json._skip_decisions }}",
              "rightValue": "={{ false }}",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "nocodb-insert-decision",
      "name": "NocoDB Insert Decision",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
