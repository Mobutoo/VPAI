# {{ ansible_managed }}
# MeTube environment — video downloader (yt-dlp web UI)

DOWNLOAD_DIR=/downloads
OUTPUT_TEMPLATE={{ metube_output_template }}
{% if videoref_port | default('') | string | length > 0 %}
# yt-dlp exec postprocessor: notify VideoRef Engine after each download
# Uses wget (available in container) to POST filename to VideoRef webhook
# Container hostname workstation_videoref is resolvable on Docker network 'creative'
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best","exec":"wget -qO- --post-data='{\"filename\":\"%(filename)s\"}' --header='Content-Type: application/json' http://workstation_videoref:{{ videoref_port }}/api/webhook/metube 2>/dev/null || true"}
{% else %}
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best"}
{% endif %}
