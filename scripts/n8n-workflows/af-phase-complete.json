          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ Id: $('Fetch Current Status').first().json.list[0].Id, phases_completed: $json.phases_completed, total_duration: $json.total_duration, status: $json.status }) }}",
        "options": {}
      }
    }
