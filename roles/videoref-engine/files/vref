#!/usr/bin/env python3
"""vref — VideoRef Engine CLI v0.7.0.

Universal CLI for the VideoRef creative pipeline.
Calls the VideoRef Engine REST API on Waza (RPi5).

Usage:
    vref health                          # Check service status
    vref watch                           # List downloaded videos awaiting analysis
    vref jobs                            # List completed analyses
    vref analyze <filename> [--template] # Analyze a video (multi-scene)
    vref assets [--style X] [--mood Y]   # Search VideoRef assets in Kitsu
    vref get <asset_id>                  # Get full asset details + prompt
    vref search <query>                  # Semantic search via Qdrant embeddings
    vref remix <asset_id> [--subject X]  # Remix an asset with modifications
    vref prompt <asset_id>               # Print just the AI prompt (for piping)
    vref cameras                         # List available camera presets
    vref produce-start [--title T]       # Start a new production job
    vref produce-step JOB_ID STEP        # Execute a pipeline step
    vref produce-status JOB_ID           # Show job status
    vref produce-retake JOB_ID STEP      # Retake a specific step

Environment:
    VREF_URL    Base URL (default: https://cine.ewutelo.cloud)

Examples:
    vref assets --style 3D --mood playful
    vref get abc123 | jq .ai_prompt
    vref remix abc123 --subject "cats" --style "watercolor" --mood "sad"
    vref remix abc123 --camera ARRI --lens anamorphic --subject "cats"
    vref search "dramatic cinematic dark blue"
    vref prompt abc123 | pbcopy   # Copy prompt to clipboard
    vref analyze "video.mp4" --template cinematic
    vref cameras
    vref produce-start --title "Cats Ghibli" --camera ARRI --lens anamorphic
    vref produce-step JOB_ID brief --description "A short film about cats"
    vref produce-status JOB_ID
    vref produce-retake JOB_ID imagegen --scenes 3,5
"""
import argparse
import json
import os
import sys
import urllib.request
import urllib.error

BASE_URL = os.environ.get("VREF_URL", "https://cine.ewutelo.cloud")

PIPELINE_STEPS = [
    "brief", "research", "script", "storyboard", "voiceover", "music",
    "imagegen", "videogen", "montage", "subtitles", "colorgrade",
    "review", "export", "publish",
]


def _api(method: str, path: str, body: dict | None = None) -> dict:
    """Call VideoRef Engine API."""
    from urllib.parse import quote
    # Encode query string spaces but keep ? and & and =
    if "?" in path:
        base, qs = path.split("?", 1)
        parts = []
        for param in qs.split("&"):
            if "=" in param:
                k, v = param.split("=", 1)
                parts.append(f"{k}={quote(v)}")
            else:
                parts.append(quote(param))
        path = f"{base}?{'&'.join(parts)}"
    url = f"{BASE_URL}{path}"
    data = json.dumps(body).encode() if body else None
    headers = {"Content-Type": "application/json"} if body else {}
    req = urllib.request.Request(url, data=data, method=method, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = e.read().decode()[:500]
        try:
            return json.loads(err)
        except Exception:
            return {"error": f"HTTP {e.code}: {err}"}
    except urllib.error.URLError as e:
        return {"error": f"Connection failed: {e.reason}"}


def _print_json(data: dict, compact: bool = False) -> None:
    """Print JSON to stdout."""
    if compact:
        print(json.dumps(data))
    else:
        print(json.dumps(data, indent=2, ensure_ascii=False))


def _print_table(rows: list[dict], columns: list[str], widths: list[int]) -> None:
    """Print a simple table."""
    header = "  ".join(c.upper().ljust(w) for c, w in zip(columns, widths))
    print(header)
    print("-" * len(header))
    for row in rows:
        line = "  ".join(
            str(row.get(c, ""))[:w].ljust(w) for c, w in zip(columns, widths)
        )
        print(line)


# -- Commands (existing) ------------------------------------------

def cmd_health(args: argparse.Namespace) -> None:
    """Check service health."""
    data = _api("GET", "/health")
    if args.json:
        _print_json(data)
        return
    status = data.get("status", "?")
    version = data.get("version", "?")
    integrations = data.get("integrations", {})
    icon = "OK" if status == "ok" else "FAIL"
    print(f"[{icon}] VideoRef Engine v{version}")
    for name, active in integrations.items():
        print(f"  [{'x' if active else ' '}] {name}")


def cmd_watch(args: argparse.Namespace) -> None:
    """List files in watch directory."""
    data = _api("GET", "/api/watch")
    if args.json:
        _print_json(data)
        return
    files = data.get("files", [])
    print(f"{data.get('count', 0)} files in watch dir:\n")
    for f in files:
        print(f"  {f}")


def cmd_jobs(args: argparse.Namespace) -> None:
    """List completed analyses."""
    data = _api("GET", "/api/jobs")
    if args.json:
        _print_json(data)
        return
    analyzed = data.get("analyzed", [])
    print(f"{data.get('count', 0)} completed analyses:\n")
    for f in analyzed:
        print(f"  {f}")


def cmd_analyze(args: argparse.Namespace) -> None:
    """Analyze a video file."""
    body = {"filename": args.filename, "template": args.template}
    print(f"Analyzing '{args.filename}' (template: {args.template})...")
    print("   This may take 1-5 minutes for Claude Vision analysis.\n")
    data = _api("POST", "/api/analyze", body)
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    print(f"Status: {data.get('status')} | Scenes: {data.get('scene_count')}")
    k = data.get("kitsu", {})
    if isinstance(k.get("sequence_id"), str):
        print(f"   Kitsu: {k.get('shot_count')} shots, {k.get('asset_count')} assets, {k.get('preview_count')} previews")
    elif k.get("error"):
        print(f"   Kitsu: {k['error'][:80]}")
    print(f"   Qdrant: {'indexed' if data.get('qdrant', {}).get('indexed') else 'skipped'}")
    print(f"   Gitea: {'versioned' if data.get('gitea', {}).get('versioned') else 'skipped'}")
    print(f"\n{'=' * 70}")
    for i, scene in enumerate(data.get("scenes", [])):
        a = scene.get("analysis", {})
        print(f"  Scene {i+1}: {a.get('style', '?')[:35]} | {a.get('mood', '?')[:25]}")


def cmd_assets(args: argparse.Namespace) -> None:
    """Search VideoRef assets."""
    params = []
    if args.style:
        params.append(f"style={args.style}")
    if args.mood:
        params.append(f"mood={args.mood}")
    if args.motion:
        params.append(f"motion={args.motion}")
    if args.query:
        params.append(f"q={args.query}")
    if args.limit:
        params.append(f"limit={args.limit}")
    qs = "&".join(params)
    path = f"/api/assets?{qs}" if qs else "/api/assets"
    data = _api("GET", path)
    if args.json:
        _print_json(data)
        return
    assets = data.get("assets", [])
    print(f"{data.get('count', 0)} assets found (of {data.get('total', '?')} total):\n")
    for a in assets:
        print(f"  {a['name'][:65]}")
        print(f"     ID: {a['id']}")
        print(f"     Style: {a.get('style', '')[:40]} | Mood: {a.get('mood', '')[:25]}")
        prompt = a.get("ai_prompt", "")
        if prompt:
            print(f"     Prompt: {prompt[:80]}...")
        print()


def cmd_get(args: argparse.Namespace) -> None:
    """Get full asset details."""
    data = _api("GET", f"/api/assets/{args.asset_id}")
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    print(f"Asset: {data.get('name', '?')}")
    print(f"   ID:      {data.get('id', '?')}")
    print(f"   Style:   {data.get('style', '?')}")
    print(f"   Mood:    {data.get('mood', '?')}")
    print(f"   Colors:  {data.get('colors', '?')}")
    print(f"   Motion:  {data.get('motion', '?')}")
    print(f"   Created: {data.get('created_at', '?')}")
    print(f"\n{'=' * 70}")
    print(f"AI Prompt:\n{data.get('ai_prompt', 'N/A')}")


def cmd_prompt(args: argparse.Namespace) -> None:
    """Print just the AI prompt (for piping)."""
    data = _api("GET", f"/api/assets/{args.asset_id}")
    prompt = data.get("ai_prompt", data.get("error", ""))
    print(prompt)


def cmd_search(args: argparse.Namespace) -> None:
    """Semantic search via Qdrant."""
    query = " ".join(args.query)
    params = f"q={query}&limit={args.limit}"
    data = _api("GET", f"/api/search?{params}")
    if args.json:
        _print_json(data)
        return
    results = data.get("results", [])
    print(f"'{query}' -- {data.get('count', 0)} results:\n")
    for r in results:
        score = r.get("score", 0)
        bar = "#" * int(score * 20) + "." * (20 - int(score * 20))
        print(f"  [{bar}] {score:.3f}")
        print(f"    Style: {r.get('style', '?')[:40]} | Mood: {r.get('mood', '?')[:25]}")
        prompt = r.get("suggested_prompt", "")
        if prompt:
            print(f"    Prompt: {prompt[:80]}...")
        print()


def cmd_remix(args: argparse.Namespace) -> None:
    """Remix an asset with modifications."""
    modifications = {}
    if args.subject:
        modifications["subject"] = args.subject
    if args.style:
        modifications["style"] = args.style
    if args.mood:
        modifications["mood"] = args.mood
    if args.colors:
        modifications["colors"] = args.colors
    if args.extra:
        modifications["extra"] = args.extra

    if not modifications and not args.source_prompt and not args.camera:
        print("Error: Provide at least one modification (--subject, --style, --mood, --colors, --extra, --camera)")
        sys.exit(1)

    body = {
        "template": args.template,
        "output_name": args.output or "remix",
        "modifications": modifications,
    }
    if args.source_prompt:
        body["source_prompt"] = args.source_prompt
    else:
        body["asset_id"] = args.asset_id

    # Camera params
    if args.camera:
        body["camera"] = args.camera
    if args.lens:
        body["lens"] = args.lens
    if args.aperture:
        body["aperture"] = args.aperture
    if args.cam_motion:
        body["motion"] = args.cam_motion

    print(f"Remixing with: {modifications}")
    if args.camera:
        print(f"   Camera: {args.camera} | Lens: {args.lens or 'default'}")
    print(f"   Template: {args.template}\n")

    data = _api("POST", "/api/remix", body)
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    print(f"Remix complete!")
    print(f"\n{'=' * 70}")
    print(f"Original:  {data.get('original_prompt', '')[:80]}...")
    print(f"\n{'=' * 70}")
    print(f"Remixed:   {data.get('remixed_prompt', '')}")
    print(f"\n{'=' * 70}")
    print(f"Style:     {data.get('style', '?')}")
    print(f"Mood:      {data.get('mood', '?')}")
    cam = data.get("camera_tokens", {})
    if cam.get("camera"):
        print(f"Camera:    {cam.get('camera', '')} | Lens: {cam.get('lens', '')} | f/{cam.get('aperture', '')}")
    print(f"Workflow:   {data.get('workflow_path', '?')}")


