# {{ ansible_managed }}
# Koodia food cockpit environment configuration

NODE_ENV=production

# Mealie API (internal Docker network)
MEALIE_URL=http://mealie:{{ mealie_web_port | default(9000) }}
MEALIE_API_TOKEN={{ mealie_api_token | default('') }}

# Grocy API (internal Docker network)
GROCY_URL=http://grocy:{{ grocy_web_port | default(80) }}
GROCY_API_KEY={{ grocy_api_key | default('') }}

# LiteLLM proxy (internal Docker network — AI features)
LITELLM_URL=http://litellm:4000
LITELLM_KEY={{ litellm_master_key }}
LLM_MODEL={{ koodia_llm_model }}

# Qdrant vector store (internal Docker network — semantic search)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY={{ qdrant_api_key | default('') }}

# OpenClaw integration (internal Docker network)
OPENCLAW_URL=http://openclaw:18789
OPENCLAW_WEBHOOK_SECRET={{ openclaw_webhook_secret | default('') }}

# Application security
SESSION_SECRET={{ koodia_session_secret }}

# Timezone
TZ={{ timezone }}
