# {{ sd_project_name }} — Environment variables
# Managed by Ansible — DO NOT EDIT MANUALLY

# --- Timezone ---
TZ=Europe/Paris

# --- PostgreSQL admin ---
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD={{ sd_postgres_admin_password }}

# --- Zammad DB ---
ZAMMAD_DB_USER={{ sd_zammad_db_user }}
ZAMMAD_DB_PASSWORD={{ sd_zammad_db_password }}
ZAMMAD_DB_NAME={{ sd_zammad_db_name }}

# --- Discourse DB ---
DISCOURSE_DB_USER={{ sd_discourse_db_user }}
DISCOURSE_DB_PASSWORD={{ sd_discourse_db_password }}
DISCOURSE_DB_NAME={{ sd_discourse_db_name }}

# --- Service Desk app DB ---
SERVICEDESK_DB_USER={{ sd_servicedesk_db_user }}
SERVICEDESK_DB_PASSWORD={{ sd_servicedesk_db_password }}
SERVICEDESK_DB_NAME={{ sd_servicedesk_db_name }}

# --- Discourse admin ---
DISCOURSE_ADMIN_USER={{ sd_discourse_admin_user }}
DISCOURSE_ADMIN_PASSWORD={{ sd_discourse_admin_password }}
DISCOURSE_ADMIN_EMAIL={{ sd_discourse_admin_email }}

# --- Discourse host ---
DISCOURSE_HOST=agence.{{ sd_domain }}

# --- Zammad host ---
ZAMMAD_FQDN=help.{{ sd_domain }}

# --- SMTP (Brevo) ---
SMTP_HOST={{ sd_smtp_host }}
SMTP_PORT={{ sd_smtp_port }}
SMTP_USER={{ sd_smtp_user }}
SMTP_PASSWORD={{ sd_smtp_password }}

# --- Brevo API ---
BREVO_API_KEY={{ sd_brevo_api_key }}

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN={{ sd_telegram_bot_token }}
TELEGRAM_CHAT_ID={{ sd_telegram_chat_id }}

# --- Qdrant ---
QDRANT_API_KEY={{ sd_qdrant_api_key }}

# --- Typesense ---
TYPESENSE_API_KEY={{ sd_typesense_api_key }}

# --- LiteLLM ---
LITELLM_URL={{ sd_litellm_url }}
LITELLM_API_KEY={{ sd_litellm_api_key }}

# --- Zammad API token ---
ZAMMAD_API_TOKEN={{ sd_zammad_api_token | default('placeholder-generate-after-setup') }}

# --- Zitadel SSO ---
ZITADEL_ISSUER=https://auth.{{ sd_domain }}
ZITADEL_SD_CLIENT_ID={{ sd_zitadel_client_id | default('placeholder-create-in-zitadel') }}

# --- NextAuth ---
NEXTAUTH_SECRET={{ sd_nextauth_secret }}

# --- Embedding model ---
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-sonnet-4-6

# --- Ports ---
ZAMMAD_PORT={{ sd_zammad_port }}
DISCOURSE_PORT={{ sd_discourse_port }}
QDRANT_PORT={{ sd_qdrant_port }}
TYPESENSE_PORT={{ sd_typesense_port }}
RERANKER_PORT={{ sd_reranker_port }}
SUPPORT_AGENT_PORT={{ sd_support_agent_port }}
GATUS_PORT={{ sd_gatus_port }}
PORTAIL_PORT={{ sd_portail_port }}
EVENT_ROUTER_PORT={{ sd_event_router_port }}
