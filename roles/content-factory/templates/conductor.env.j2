# {{ ansible_managed }}
# Content Factory Conductor (services/conductor — Temporal worker)
CF_TEMPORAL_HOST={{ cf_temporal_host }}
CF_TEMPORAL_NAMESPACE={{ cf_temporal_namespace }}
CF_TASK_QUEUE={{ cf_task_queue }}
CF_API_BASE_URL={{ cf_api_internal_base_url }}
# Bearer envoyé par cf_client.py vers cf-api (audit C2/A1.2). Source vault: vault_cf_api_token.
CF_API_TOKEN={{ cf_api_token }}
# Plane adapter (write-only projection; secrets via vault) — see services/plane-adapter/README.md
PLANE_BASE_URL={{ cf_plane_base_url }}
PLANE_API_TOKEN={{ cf_plane_api_token }}
PLANE_PROJECT_ID={{ cf_plane_project_id }}
PLANE_WORKSPACE_SLUG={{ cf_plane_workspace_slug }}
# Cert self-signed Tailscale sur Plane — CA pinning = amélioration future.
PLANE_TLS_VERIFY=false
# GPU dispatch (I5 — services/conductor/activities_gpu.py, PodPilot -> RunPod Serverless).
# Gate : défaut OFF ("0") => generate_take_gpu reste un NO-OP complet (aucun réseau
# PodPilot/RunPod), comportement pré-I5 inchangé. Passage à "1" = geste humain séparé
# du déploiement Ansible (cf. docs/specs/2026-07-06-serverless-entrypoint-M1.md côté repo
# content-factory, section "Gates humains restants").
CF_GPU_LIVE={{ cf_gpu_live }}
CF_PODPILOT_PROJECT={{ cf_podpilot_project }}
CF_PODPILOT_POLICY={{ cf_podpilot_policy }}
CF_GPU_POLL_INTERVAL_S={{ cf_gpu_poll_interval_s }}
CF_GPU_POLL_TIMEOUT_S={{ cf_gpu_poll_timeout_s }}
# PodPilotClient.from_env() (packages/providers/podpilot_client.py) lit os.environ["PODPILOT_URL"]
# (clé présente via env_file même si vide — pas de KeyError ici). Une valeur vide fait
# échouer le 1er appel resolve() -> capturé par le filet générique de l'activity ->
# take=failed. PodPilot tourne aujourd'hui en LOOPBACK sur waza (127.0.0.1:8000,
# RUNBOOK-PODPILOT-WAZA.md côté repo content-factory), injoignable depuis un conteneur
# Sese-AI : reste vide tant que l'exposition réseau (Tailscale ?) n'est pas tranchée
# séparément — NE PAS deviner une URL.
PODPILOT_URL={{ cf_podpilot_url }}
# Idem (clé présente, vide par défaut tant que le vault n'est pas provisionné). Doit être
# la clé WORKER (scopes read+ingest), jamais la clé admin — RUNBOOK-PODPILOT-WAZA.md §6/§7.
PODPILOT_API_KEY={{ cf_podpilot_api_key }}
# RunPodDispatchClient.from_env() (packages/providers/runpod_dispatch.py) lit
# os.environ.get("RUNPOD_API_KEY", "") — pas de KeyError, mais chaîne vide fait lever
# RunPodDispatchError (garde anti-dépense explicite, cf. docstring du client).
RUNPOD_API_KEY={{ cf_runpod_api_key }}
