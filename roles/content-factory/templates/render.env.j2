# {{ ansible_managed }}
# Content Factory cf-render (services/render — worker Temporal V-2 découpe → plans)
CF_TEMPORAL_HOST={{ cf_temporal_host }}
CF_TEMPORAL_NAMESPACE={{ cf_temporal_namespace }}
CF_RENDER_TASK_QUEUE={{ cf_render_task_queue }}
# Write-back des résultats (PATCH /references/{id}/meta, POST /references/{id}/derived)
# — worker fail-fast au boot si absent (worker.py assert_io_configured).
CF_API_BASE_URL={{ cf_api_internal_base_url }}
CF_API_TOKEN={{ cf_api_token }}
# Volume partagé cf_media (mêmes conventions de chemin que cf-api).
CF_MEDIA_DIR=/media
# 1 job média à la fois (ThreadPoolExecutor) — spec §Risques RAM Sese.
CF_RENDER_CONCURRENCY={{ cf_render_concurrency }}
# V5-B — Remotion Render Server (waza, mesh). PIÈGE REX-2026-03-22 : ne JAMAIS
# suivre job.videoUrl (REMOTION_PUBLIC_URL = vhost VPN waza) — reconstruire
# CF_REMOTION_URL/renders/{jobId}.mp4.
CF_REMOTION_URL=http://{{ cf_remotion_mesh_url }}
CF_REMOTION_TOKEN={{ vault_remotion_api_token }}
# V-4 — vision Qwen2.5-VL (endpoint RunPod cf-vision, résolu via PodPilot
# policy cf-vision-describe). Gate dépense : CF_VISION_LIVE (défaut "0") —
# l'activity vision_describe est un no-op réseau tant que non flippé.
# Sans RUNPOD_API_KEY, LlmDispatchClient.from_env() lève LlmError.
CF_VISION_LIVE={{ cf_vision_live }}
# T5 — nl-edit (texte libre -> op_plan via LLM, workflow NlEditWorkflow).
# Gate depense : CF_LLM_LIVE (meme var que le conducteur — decompo).
CF_LLM_LIVE={{ cf_llm_live }}
PODPILOT_URL={{ cf_podpilot_url }}
PODPILOT_API_KEY={{ cf_podpilot_api_key }}
RUNPOD_API_KEY={{ cf_runpod_api_key }}
