# {{ ansible_managed }}
# n8n environment configuration

# Database
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgresql
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD={{ postgresql_password }}
# Pool size — default 2 is a bottleneck with concurrent workflows
DB_POSTGRESDB_POOL_SIZE={{ n8n_db_pool_size | default(10) }}

# Encryption
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}

# URLs
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
# Proxy trust — Caddy reverse proxy adds X-Forwarded-For (1 hop)
# Without this, express-rate-limit throws ERR_ERL_UNEXPECTED_X_FORWARDED_FOR
N8N_PROXY_HOPS=1
{% if n8n_subdomain | default('') | length > 0 %}
# Dedicated subdomain — n8n on root path (no sub-path issues)
WEBHOOK_URL=https://{{ n8n_subdomain }}.{{ domain_name }}/
N8N_EDITOR_BASE_URL=https://{{ n8n_subdomain }}.{{ domain_name }}/
{% else %}
# Sub-path mode (limited — see n8n issue #19635)
WEBHOOK_URL=https://{{ domain_name }}/n8n/
N8N_EDITOR_BASE_URL=https://{{ caddy_admin_domain }}/n8n/
{% endif %}

# User management
N8N_USER_MANAGEMENT_DISABLED=false

# Task Runners (v2.0 security)
N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=internal

# File access — restrict ReadWriteFile node to safe dirs
# /home/node/.n8n-files: n8n default user files dir
# /data/mop: MOP PDF output volume (mop-generator workflow)
N8N_RESTRICT_FILE_ACCESS_TO=/home/node/.n8n-files;/data/mop

# Code node permissions (n8n 2.0+ blocks these by default)
# fs: read/write JSON cache, path: file operations, crypto: HMAC validation
# child_process: required by existing workstation-control workflows over SSH
NODE_FUNCTION_ALLOW_BUILTIN=fs,path,crypto,child_process,http
# pg: PostgreSQL client (already installed in n8n image as internal dependency)
# Used by ai-model-scoring workflow to read/write model_scores table
NODE_FUNCTION_ALLOW_EXTERNAL=pg
# Allow Code nodes to access env vars via $env (needed for webhook secret validation)
# SECURITY TRADE-OFF: false exposes all env vars to Code nodes. Required by workflows
# using $env.N8N_WEBHOOK_HMAC_SECRET, $env.LITELLM_API_KEY, $env.GITHUB_WEBHOOK_SECRET.
# TODO: migrate to n8n Credentials store when n8n supports per-var whitelisting.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Timezone
GENERIC_TIMEZONE={{ timezone }}
TZ={{ timezone }}

# === Executions — data saving ===
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
N8N_SAVE_EXECUTION_PROGRESS=true
# Executions — pruning
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE={{ n8n_executions_max_age_hours | default(336) }}
EXECUTIONS_DATA_PRUNE_MAX_COUNT={{ n8n_executions_max_count | default(10000) }}
# Executions — safety limits
EXECUTIONS_TIMEOUT={{ n8n_execution_timeout | default(3600) }}
EXECUTIONS_TIMEOUT_MAX={{ n8n_execution_timeout_max | default(7200) }}
N8N_CONCURRENCY_PRODUCTION_LIMIT={{ n8n_concurrency_limit | default(20) }}

# === Templates — workflow library (1000+ templates) ===
# Templates: must differ from hardcoded "https://api.n8n.io/api/" to enable
# in-app template gallery (otherwise n8n opens n8n.io in a new tab).
# Trailing slash difference is enough to trigger hasCustomTemplatesHost=true.
N8N_TEMPLATES_ENABLED=true
N8N_TEMPLATES_HOST=https://api.n8n.io/api

# === Metrics — Prometheus/VictoriaMetrics endpoint ===
N8N_METRICS=true
N8N_METRICS_PREFIX=n8n_
N8N_METRICS_INCLUDE_DEFAULT_METRICS=true
N8N_METRICS_INCLUDE_WORKFLOW_ID_LABEL=true
N8N_METRICS_INCLUDE_NODE_TYPE_LABEL=true
N8N_METRICS_INCLUDE_CACHE_METRICS=true
N8N_METRICS_INCLUDE_API_ENDPOINTS=true
N8N_METRICS_INCLUDE_API_METHOD_LABEL=true
N8N_METRICS_INCLUDE_API_STATUS_CODE_LABEL=true

# === Community packages ===
N8N_COMMUNITY_PACKAGES_ENABLED=true

# === Logging ===
N8N_LOG_LEVEL={{ n8n_log_level | default('info') }}
N8N_LOG_OUTPUT=console
# Code node console.log() visible in docker logs
CODE_ENABLE_STDOUT=true

# === Payload limits ===
# Default 16 MiB too small for file processing (images, PDFs, CSVs)
N8N_PAYLOAD_SIZE_MAX={{ n8n_payload_size_max | default(64) }}

# === Privacy — disable telemetry to n8n Inc ===
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=true
N8N_HIRING_BANNER_ENABLED=false
N8N_PERSONALIZATION_ENABLED=true
N8N_ONBOARDING_FLOW_DISABLED=false

# === AI — timeout for LLM nodes ===
N8N_AI_TIMEOUT_MAX={{ n8n_ai_timeout_max | default(300000) }}

# === Public API ===
N8N_PUBLIC_API_DISABLED=false

# === Security hardening ===
N8N_SECURE_COOKIE=true

# === License — enterprise patch (no phone-home to license.n8n.io) ===
# Server URL pointed to localhost (never contacts official server)
N8N_LICENSE_SERVER_URL=http://localhost:1/
# Auto-renewal disabled (cert renewal would fail and log errors)
N8N_LICENSE_AUTO_RENEW_ENABLED=false
{% if n8n_license_activation_key | default('') | length > 0 %}
N8N_LICENSE_ACTIVATION_KEY={{ n8n_license_activation_key }}
{% endif %}
N8N_HIDE_USAGE_PAGE=false

# === Insights (available with community license, detailed with Pro+) ===
N8N_INSIGHTS_ENABLED={{ n8n_insights_enabled | default('true') }}

# ===================================================================
# Integration env vars (custom — read by workflows via $env.XXX)
# ===================================================================

# OpenClaw <-> n8n webhook integration
# Custom env var read by n8n workflows via {{ '$env.N8N_WEBHOOK_HMAC_SECRET' }}
# to validate incoming webhook calls from OpenClaw (not a built-in n8n feature)
{% if n8n_webhook_secret | default('') | length > 0 %}
N8N_WEBHOOK_HMAC_SECRET={{ n8n_webhook_secret }}
{% endif %}

# LiteLLM API key — used by AI workflows (translate, summarize, format)
# to call LiteLLM proxy at http://litellm:4000 via $env.LITELLM_API_KEY
LITELLM_API_KEY={{ litellm_master_key }}

# Telegram monitoring bot — used by budget-monitor + budget-control workflows
# to send alerts and budget status notifications
{% if telegram_monitoring_bot_token | default('') | length > 0 %}
TELEGRAM_MONITORING_BOT_TOKEN={{ telegram_monitoring_bot_token }}
TELEGRAM_MONITORING_CHAT_ID={{ telegram_monitoring_chat_id }}
{% endif %}

# GitHub webhook secret — used by github-autofix workflow to validate HMAC signatures
# (X-Hub-Signature-256) from GitHub webhook events
{% if github_webhook_secret | default('') | length > 0 %}
GITHUB_WEBHOOK_SECRET={{ github_webhook_secret }}
{% endif %}

# Workstation Pi SSH — used by github-autofix + code-review workflows to execute commands remotely
# Uses Tailscale IP (not LAN IP) — n8n runs on VPS and reaches RPi via mesh VPN
{% if workstation_pi_tailscale_ip | default('') | length > 0 %}
WORKSTATION_PI_IP={{ workstation_pi_tailscale_ip }}
WORKSTATION_PI_USER={{ workstation_pi_user | default('pi') }}
WORKSTATION_SSH_KEY_PATH={{ workstation_ssh_key_path | default('/home/node/.ssh/id_ed25519') }}
{% if opencut_subdomain | default('') | length > 0 %}
OPENCUT_DOMAIN={{ opencut_subdomain }}.{{ domain_name }}
{% endif %}
{% endif %}

# NocoDB integration (pipeline production IA manga)
NOCODB_BASE_URL=https://{{ nocodb_subdomain }}.{{ domain_name }}
NOCODB_API_TOKEN={{ nocodb_api_token }}

# NocoDB Content Factory table IDs (set by provisioning or manually)
NOCODB_CF_BASE_ID={{ nocodb_cf_base_id | default('') }}
NOCODB_CONTENTS_TABLE_ID={{ nocodb_contents_table_id | default('') }}
NOCODB_SCENES_TABLE_ID={{ nocodb_scenes_table_id | default('') }}
NOCODB_BRANDS_TABLE_ID={{ nocodb_brands_table_id | default('') }}

# Fal.ai API key — used by content factory workflows for AI image/video generation
{% if fal_ai_api_key | default('') | length > 0 %}
FAL_KEY={{ fal_ai_api_key }}
{% endif %}

# Plane integration (project management — Phase 2)
PLANE_TOKEN_CONCIERGE={{ vault_plane_agent_tokens.concierge | default('') }}
PLANE_PUBLIC_URL=https://work.{{ domain_name }}

# Kitsu/Zou integration (Content Factory production tracking)
{% if vault_kitsu_bot_email is defined and vault_kitsu_bot_email | length > 0 %}
KITSU_BOT_EMAIL={{ vault_kitsu_bot_email }}
KITSU_BOT_PASSWORD={{ vault_kitsu_bot_password }}
{% endif %}
# Internal Docker URL for Zou API (kitsu container runs nginx+gunicorn on port 80)
KITSU_API_URL=http://kitsu:80

# Plane API key for editorial calendar sync (calendar-sync workflow)
{% if vault_plane_api_key is defined and vault_plane_api_key | length > 0 %}
PLANE_API_KEY={{ vault_plane_api_key }}
{% endif %}

# Plane project IDs for calendar sync (Content Factory)
PLANE_WORKSPACE_SLUG={{ plane_workspace_slug | default('ewutelo') }}
PLANE_CF_PROJECT_ID={{ plane_cf_project_id | default('') }}
PLANE_CF_MODULE_ID={{ plane_cf_module_id | default('') }}

# Remotion API key — used by creative-pipeline workflow for authenticated renders
{% if vault_remotion_api_token | default('') | length > 0 %}
REMOTION_API_KEY={{ vault_remotion_api_token }}
{% endif %}

# BytePlus API key — used by creative-pipeline workflow for Seedance video generation
{% if byteplus_api_key | default('') | length > 0 %}
BYTEPLUS_API_KEY={{ byteplus_api_key }}
{% endif %}

# === App Factory (af-* workflows) ===
AF_WEBHOOK_SECRET={{ af_webhook_secret }}
GITHUB_TOKEN={{ vault_ghcr_pull_token }}
LITELLM_MASTER_KEY={{ litellm_master_key }}
QDRANT_API_KEY={{ qdrant_api_key }}
PLANE_API_TOKEN={{ vault_plane_api_token | default(vault_plane_admin_api_token) }}

# === LlamaIndex memory worker (memory-* workflows) ===
# Shared secret for X-Memory-Secret header on memory-run-report webhook.
# Worker on Waza posts its JSON report with this token.
MEMORY_WEBHOOK_SECRET={{ memory_webhook_secret }}
# Healthcheck thresholds (memory-healthcheck workflow).
MEMORY_HEALTHCHECK_MAX_AGE_HOURS={{ memory_healthcheck_max_age_hours | default(2) }}
MEMORY_HEALTHCHECK_MAX_SPOOL={{ memory_healthcheck_max_spool | default(50) }}
# Telegram webhook secret token for the memory-telegram-bot workflow.
# Telegram sends this back as X-Telegram-Bot-Api-Secret-Token header on every
# update so we can distinguish real Telegram POSTs from random internet traffic
# on the public webhook URL.
MEMORY_TELEGRAM_WEBHOOK_SECRET={{ memory_telegram_webhook_secret }}

# === MOP Machinery ===
# Public base URL for PDF download links returned by the render workflow.
# Used by the Persist Code node — avoids hardcoding the domain in the workflow JSON.
MOP_PUBLIC_BASE=https://mop-dl.{{ domain_name }}
