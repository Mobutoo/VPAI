# Palais Environment — Generated by Ansible
# Do not edit manually

# Database
DATABASE_URL=postgresql://{{ palais_db_user }}:{{ palais_db_password }}@postgresql:5432/{{ palais_db_name }}

# OpenClaw
OPENCLAW_WS_URL=ws://openclaw:18789

# LiteLLM
LITELLM_URL=http://litellm:4000
LITELLM_KEY={{ litellm_master_key }}

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION={{ palais_qdrant_collection }}

# Provider API Keys (LiteLLM proxy tracking)
OPENROUTER_API_KEY={{ openrouter_api_key | default('') }}
ANTHROPIC_API_KEY={{ anthropic_api_key }}

# Budget limits (daily, USD)
BUDGET_DAILY_LIMIT={{ litellm_anthropic_budget_daily | float + litellm_openai_budget_daily | float + litellm_openrouter_budget_daily | float }}

# n8n Webhooks
N8N_WEBHOOK_BASE=http://n8n:5678/webhook

# n8n Deploy webhooks (Palais v2 — deploy pipeline)
N8N_DEPLOY_WEBHOOK={{ n8n_deploy_webhook | default('') }}
N8N_PROVISION_WEBHOOK={{ n8n_provision_webhook | default('') }}

# Hetzner Cloud (fleet management — comma-separated for multi-project)
HETZNER_API_TOKENS={{ hetzner_api_tokens | default(hetzner_api_token | default('')) }}

# OVH API (fleet + DNS management)
OVH_ENDPOINT=https://eu.api.ovh.com/1.0
OVH_APPLICATION_KEY={{ ovh_application_key | default('') }}
OVH_APPLICATION_SECRET={{ ovh_application_secret | default('') }}
OVH_CONSUMER_KEY={{ ovh_consumer_key | default('') }}
OVH_VPS_SERVICE={{ ovh_vps_service | default('') }}

# Namecheap DNS (domain management)
NAMECHEAP_API_KEY={{ namecheap_api_key | default('') }}
NAMECHEAP_API_USER={{ namecheap_api_user | default('') }}
NAMECHEAP_CLIENT_IP={{ namecheap_client_ip | default('') }}

# Docker SSH remote (for terminal, services, waza management via SSH2)
DOCKER_SSH_SERVERS=sese-ai:{{ vps_tailscale_ip }}:{{ prod_ssh_port }},waza:{{ workstation_pi_tailscale_ip }}:22,seko-vpn:{{ vpn_tailscale_ip }}:{{ prod_ssh_port }}
DOCKER_SSH_USER={{ prod_user | default('mobuone') }}
DOCKER_SSH_KEY_PATH=/run/secrets/deploy_key

# Auth
PALAIS_API_KEY={{ palais_api_key }}
PALAIS_ADMIN_PASSWORD={{ palais_admin_password }}
SESSION_SECRET={{ palais_session_secret }}

# Server
PORT={{ palais_port }}
HOST=0.0.0.0
ORIGIN=https://{{ palais_subdomain }}.{{ domain_name }}
NODE_ENV=production
TZ={{ timezone }}

# Headscale (VPN topology — Module 11)
HEADSCALE_URL={{ vpn_headscale_url | default('') }}
HEADSCALE_API_KEY={{ palais_headscale_api_key | default('') }}

# Claude Code MCP (Module 13)
PALAIS_URL=https://{{ palais_subdomain }}.{{ domain_name }}

# Monthly budget limit (EUR) for cost gauge
BUDGET_MONTHLY_LIMIT_EUR={{ palais_budget_monthly_limit | default('50') }}

# Node IPs (Tailscale/Singa + Local) — for initial DB seed
SESE_AI_TAILSCALE_IP={{ vps_tailscale_ip | default('') }}
SESE_AI_LOCAL_IP={{ prod_ssh_host | default('') }}
WORKSTATION_PI_TAILSCALE_IP={{ workstation_pi_tailscale_ip | default('') }}
WORKSTATION_PI_LOCAL_IP={{ workstation_pi_local_ip | default('') }}
SEKO_VPN_TAILSCALE_IP={{ vpn_tailscale_ip | default('') }}
SEKO_VPN_LOCAL_IP={{ vpn_server_ip | default('') }}
