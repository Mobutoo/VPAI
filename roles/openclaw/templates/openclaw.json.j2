{
  "gateway": {
    "mode": "local",
    "port": {{ openclaw_gateway_port }},
    "bind": "{{ openclaw_gateway_bind }}",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["{{ docker_network_backend_subnet }}"],
    "controlUi": {
      "enabled": true,
      "basePath": "/",
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "https://{{ admin_subdomain }}.{{ domain_name }}",
        "https://{{ nocodb_subdomain }}.{{ domain_name }}"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "{{ openclaw_system_dir }}/workspace",
      "userTimezone": "{{ timezone }}",
      "model": {
        "primary": "{{ openclaw_default_model }}"
      },
      "sandbox": {
        "mode": "{{ openclaw_sandbox_mode | default('non-main') }}",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "{{ openclaw_sandbox_image | default('openclaw-sandbox:bookworm-slim') }}",
          "readOnlyRoot": true,
          "tmpfs": ["/tmp", "/var/tmp", "/run"],
          "network": "{{ project_name }}_sandbox",
          "user": "1000:1000",
          "capDrop": ["ALL"],
          "pidsLimit": 256,
          "memory": "{{ openclaw_sandbox_memory | default('1g') }}",
          "cpus": {{ openclaw_sandbox_cpus | default(1) }}
        },
        "prune": {
          "idleHours": 24,
          "maxAgeDays": 7
        }
      },
      "subagents": {
        "maxConcurrent": 4,
        "archiveAfterMinutes": 120
      },
      "memorySearch": {
        "enabled": {{ 'true' if litellm_master_key | default('') | length > 0 else 'false' }}
      },
      "contextTokens": {{ openclaw_context_tokens | default(128000) }},
      "compaction": {
        "mode": "{{ openclaw_compaction_mode | default('default') }}",
        "reserveTokensFloor": {{ openclaw_compaction_reserve_tokens | default(24000) }},
        "postCompactionSections": {{ openclaw_compaction_sections | default('["Regles Systeme", "Discipline"]') }},
        "memoryFlush": {
          "enabled": {{ openclaw_memory_flush_enabled | default(true) | lower }},
          "softThresholdTokens": {{ openclaw_memory_flush_threshold | default(6000) }},
          "systemPrompt": "Session pres de la compaction. Sauvegarde les informations importantes dans la memoire (Qdrant) avant qu'elles ne soient resumees.",
          "prompt": "Ecris des notes durables en memoire pour les faits, decisions et contexte importants de cette session qui ne doivent pas etre perdus lors de la compaction."
        }
      },
      "contextPruning": {
        "mode": "{{ openclaw_context_pruning_mode | default('cache-ttl') }}",
        "ttl": "{{ openclaw_context_pruning_ttl | default('1h') }}",
        "keepLastAssistants": {{ openclaw_context_pruning_keep | default(3) }},
        "minPrunableToolChars": {{ openclaw_context_pruning_min_chars | default(50000) }},
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Ancien resultat d'outil supprime — relancer si necessaire]"
        }
      },
      "bootstrapPromptTruncationWarning": "once"
    },
    "list": [
      {
        "id": "{{ openclaw_agent_concierge_name }}",
        "default": true,
        "model": {
          "primary": "{{ openclaw_concierge_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace",
        "subagents": {
          "allowAgents": [
            "{{ openclaw_agent_builder_name }}",
            "{{ openclaw_agent_writer_name }}",
            "{{ openclaw_agent_artist_name }}",
            "{{ openclaw_agent_tutor_name }}",
            "{{ openclaw_agent_explorer_name }}",
            "{{ openclaw_agent_marketer_name }}",
            "{{ openclaw_agent_cfo_name }}",
            "{{ openclaw_agent_maintainer_name }}",
            "{{ openclaw_agent_messenger_name }}"
          ]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_builder_name }}",
        "model": {
          "primary": "{{ openclaw_builder_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_builder_name }}",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "exec": {
            "applyPatch": { "workspaceOnly": true },
            "timeoutSec": 300
          },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_writer_name }}",
        "model": {
          "primary": "{{ openclaw_writer_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_writer_name }}",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_artist_name }}",
        "model": {
          "primary": "{{ openclaw_artist_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_artist_name }}",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_tutor_name }}",
        "model": {
          "primary": "{{ openclaw_tutor_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/tutor",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_explorer_name }}",
        "model": {
          "primary": "{{ openclaw_explorer_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_explorer_name }}",
        "sandbox": {
          "mode": "all",
          "docker": {
            "network": "{{ project_name }}_egress"
          }
        },
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_marketer_name }}",
        "model": {
          "primary": "{{ openclaw_marketer_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_marketer_name }}",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_cfo_name }}",
        "model": {
          "primary": "{{ openclaw_cfo_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/finance",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_maintainer_name }}",
        "model": {
          "primary": "{{ openclaw_maintainer_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_maintainer_name }}",
        "subagents": {
          "allowAgents": ["{{ openclaw_agent_messenger_name }}"]
        },
        "tools": {
          "fs": { "workspaceOnly": true },
          "exec": {
            "applyPatch": { "workspaceOnly": true },
            "timeoutSec": 300
          },
          "elevated": { "enabled": false }
        }
      },
      {
        "id": "{{ openclaw_agent_messenger_name }}",
        "model": {
          "primary": "{{ openclaw_messenger_model }}"
        },
        "workspace": "{{ openclaw_system_dir }}/workspace/{{ openclaw_agent_messenger_name }}",
        "sandbox": {
          "mode": "all",
          "workspaceAccess": "ro",
          "docker": {
            "network": "{{ project_name }}_backend",
            "readOnlyRoot": true,
            "tmpfs": ["/tmp", "/var/tmp", "/run"],
            "user": "1000:1000",
            "capDrop": ["ALL"],
            "memory": "256m",
            "cpus": 0.5,
            "env": {
              "PLANE_API_URL": "http://plane-api:8000",
              "PLANE_WORKSPACE_SLUG": "{{ plane_workspace_slug | default('ewutelo') }}",
{% for agent in plane_agent_names | default(['concierge','imhotep','thot','basquiat','r2d2','piccolo','cfo','maintainer','hermes','marketer']) %}
              "PLANE_CRED_{{ agent | upper }}": "{{ vault_plane_agent_tokens[agent] | default('PROVISION_PENDING') }}"{{ ',' if not loop.last else '' }}
{% endfor %}
            }
          }
        },
        "tools": {
          "exec": { "timeoutSec": 30 },
          "elevated": { "enabled": false }
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-4o-mini",
            "name": "GPT-4o Mini (OpenAI direct)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "gpt-4o",
            "name": "GPT-4o (OpenAI direct)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 16384
          }
        ]
      },
      "custom-litellm": {
        "baseUrl": "http://litellm:4000/v1",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "claude-opus",
            "name": "Claude Opus 4 (premium)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-sonnet",
            "name": "Claude Sonnet 4 (writing/analysis)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-haiku",
            "name": "Claude Haiku 4.5 (quick/summary)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "gpt-4o",
            "name": "GPT-4o (multimodal fallback)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "gpt-4o-mini",
            "name": "GPT-4o Mini (classification)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "gpt-codex",
            "name": "GPT Codex (code review)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "qwen3-coder",
            "name": "Qwen3 Coder (FREE — mode éco)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 4096
          },
          {
            "id": "deepseek-v3",
            "name": "DeepSeek V3.2 (ultra-low — mode éco)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 4096
          },
{% if openrouter_api_key | default('') | length > 0 %}
          {
            "id": "deepseek-v3-free",
            "name": "DeepSeek V3 (FREE — 0 crédit)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 4096
          },
          {
            "id": "deepseek-r1-free",
            "name": "DeepSeek R1 (FREE — raisonnement)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 4096
          },
          {
            "id": "kimi-k2",
            "name": "Kimi K2.5 (concierge/agent)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-r1",
            "name": "DeepSeek R1 (reasoning)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-v3",
            "name": "DeepSeek V3.2 (code gen)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "glm-5",
            "name": "GLM-5 (code/agent, low hallucination)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 205000,
            "maxTokens": 16384
          },
          {
            "id": "grok-search",
            "name": "Grok 4.1 Fast (web search + X)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          },
{% endif %}
          {
            "id": "embedding",
            "name": "Embeddings (cache/RAG)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 8191,
            "maxTokens": 1
          }
        ]
      }
    }
  },
  "tools": {
    "elevated": {
      "enabled": false
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": true
      },
      "timeoutSec": 120
    },
    "fs": {
      "workspaceOnly": true
    },
    "web": {
      "search": {
        "enabled": {{ 'true' if brave_search_api_key | default('') | length > 0 else 'false' }},
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15,
        "maxRedirects": 3
      }
    }
  },
  "channels": {
{% if telegram_openclaw_bot_token | default('') | length > 0 %}
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "reactionNotifications": "own",
      "reactionLevel": "minimal",
{% if telegram_openclaw_chat_id | default('') | length > 0 %}
      "dmPolicy": "allowlist",
      "allowFrom": ["{{ telegram_openclaw_chat_id }}"],
{% endif %}
      "customCommands": [
        { "command": "tasks", "description": "Lister mes taches en cours" },
        { "command": "budget", "description": "Budget IA 24h" },
        { "command": "projects", "description": "Lister les projets actifs" }
      ]{{ ',' if openclaw_telegram_topic_routing | default(false) and telegram_openclaw_group_id | default('') | length > 0 else '' }}
{% if openclaw_telegram_topic_routing | default(false) and telegram_openclaw_group_id | default('') | length > 0 %}
      "groups": {
        "{{ telegram_openclaw_group_id }}": {
          "topics": {
{% for name, cfg in openclaw_telegram_topics.items() if cfg.topic_id | default('') | length > 0 %}
            "{{ cfg.topic_id }}": {
              "agentId": "{{ cfg.agent }}",
              "requireMention": false
            }{{ ',' if not loop.last else '' }}
{% endfor %}
          }
        }
      }
{% endif %}
    }{{ ',' if whatsapp_tutor_enabled | default(false) else '' }}
{% endif %}
{% if whatsapp_tutor_enabled | default(false) %}
    "whatsapp": {
      "provider": "baileys",
      "dmPolicy": "pairing"
    }
{% endif %}
  },
  "bindings": [
{% if telegram_openclaw_bot_token | default('') | length > 0 %}
{% if openclaw_telegram_topic_routing | default(false) and telegram_openclaw_group_id | default('') | length > 0 %}
{# Topic-specific bindings FIRST — OpenClaw uses first-match routing.
   Catch-all must come LAST or it swallows all messages → concierge only. #}
{% for name, cfg in openclaw_telegram_topics.items() if cfg.topic_id | default('') | length > 0 %}
    {
      "type": "route",
      "agentId": "{{ cfg.agent }}",
      "match": {
        "channel": "telegram",
        "accountId": "default",
        "peer": { "kind": "group", "id": "{{ telegram_openclaw_group_id }}:topic:{{ cfg.topic_id }}" }
      }
    },
{% endfor %}
{% endif %}
    {
      "type": "route",
      "agentId": "{{ openclaw_agent_concierge_name }}",
      "match": { "channel": "telegram" }
    }{{ ',' if whatsapp_tutor_enabled | default(false) else '' }}
{% endif %}
{% if whatsapp_tutor_enabled | default(false) %}
    {
      "type": "route",
      "agentId": "{{ openclaw_agent_tutor_name }}",
      "match": { "channel": "whatsapp" }
    }
{% endif %}
  ],
  "plugins": {
    "slots": {
      "contextEngine": "{{ openclaw_context_engine | default('legacy') }}"
    },
    "entries": {
{% if telegram_openclaw_bot_token | default('') | length > 0 %}
      "telegram": { "enabled": true }{{ ',' if whatsapp_tutor_enabled | default(false) else '' }}
{% endif %}
{% if whatsapp_tutor_enabled | default(false) %}
      "whatsapp": { "enabled": true }
{% endif %}
    }
  },
  "logging": {
    "level": "info"
  }
}
