      "name": "Call REX Indexer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3110,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_WEBHOOK_BASE_URL || 'http://javisi_n8n:5678' }}/webhook/af-rex-indexer",
        "sendHeaders": true,
