# {{ ansible_managed }}
# StoryEngine API + Worker environment
SE_DATABASE_URL=postgresql+asyncpg://{{ story_engine_db_user }}:{{ story_engine_db_password }}@postgres:5432/{{ story_engine_db_name }}
SE_REDIS_URL=redis://redis:6379/0
SE_QDRANT_URL=http://qdrant:6333
SE_JWT_SECRET={{ story_engine_jwt_secret }}
SE_DEBUG=false
SE_LITELLM_URL={{ story_engine_litellm_url }}
SE_LITELLM_API_KEY={{ story_engine_litellm_api_key }}
SE_EMBEDDING_MODEL={{ story_engine_embedding_model }}
SE_TOKEN_BUDGET_DAILY={{ story_engine_token_budget_daily }}
