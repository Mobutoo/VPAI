              "value": "=\ud83d\udd0d <b>VRef Remix</b> \u2014 Analyse termin\u00e9e\n\n\ud83c\udfac <b>{{ $('Validate & Prepare').first().json.title }}</b>\n\n\u2728 Remix IA en cours avec les instructions :\n<i>{{ $('Validate & Prepare').first().json.instructions.slice(0,100) }}</i>"
            }
          ]
        },
        "options": {}
      },
      "id": "vri-0001-0000-4000-8000-000000000016",
      "name": "TG: Analyzing Done",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1800,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const analysis = $('POST vref /analyze').first().json;\nconst ctx = $('Poll metube /history').first().json;\n\nconst source_prompt =\n  analysis.suggested_prompt ||\n  (analysis.scenes && analysis.scenes[0] && analysis.scenes[0].suggested_prompt) ||\n  analysis.summary ||\n  ctx.title;\n\nreturn [{ json: {\n  ...ctx,\n  analysis,\n  source_prompt,\n  remix_payload: {\n    source_prompt,\n    modifications: { subject: ctx.instructions },\n    template: 'default',\n    output_name: ctx.slug\n  }\n}}];"
      },
