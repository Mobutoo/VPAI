      "parameters": {
        "jsCode": "const nocodb = $input.first().json;\nconst ctx = $('Build Brief').first().json;\n\nconst content_id = String(nocodb.Id || nocodb.id);\n\nreturn [{ json: { ...ctx, content_id, nocodb_id: content_id } }];"
