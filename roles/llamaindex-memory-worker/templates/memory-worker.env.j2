HF_HOME={{ memory_worker_hf_home }}
SENTENCE_TRANSFORMERS_HOME={{ memory_worker_hf_home }}
# Cache FastEmbed (sparse BM25). Defaut fastembed = /tmp/fastembed_cache = tmpfs vide au
# reboot -> avec HF_HUB_OFFLINE=1 ci-dessous, modele absent = crash "Could not load Qdrant/bm25"
# (ingestion HS 28-29/06/2026). Cache persistant + pre-DL par la tache "Pre-download sparse model".
FASTEMBED_CACHE_PATH={{ memory_worker_fastembed_cache }}
PYTHONUNBUFFERED=1
HF_TOKEN={{ memory_worker_huggingface_token }}
HUGGINGFACE_HUB_TOKEN={{ memory_worker_huggingface_token }}
HF_HUB_DISABLE_TELEMETRY=1
# Offline : modèle en cache (hf-cache). Sans ça, SentenceTransformer interroge HF au
# chargement -> +réseau, et HANG possible si HF lent/injoignable (serveurs MCP coincés
# dans _load 120s = R0 interminable, REX 2026-06-07). Cache présent -> load ~2.6s.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
# Cap threads CPU de l'embed (contrôle charge, co-activité multi-sessions). waza=4 cœurs.
OMP_NUM_THREADS={{ memory_worker_cpu_threads }}
MKL_NUM_THREADS={{ memory_worker_cpu_threads }}
OPENBLAS_NUM_THREADS={{ memory_worker_cpu_threads }}
NUMEXPR_NUM_THREADS={{ memory_worker_cpu_threads }}
TORCH_NUM_THREADS={{ memory_worker_cpu_threads }}
TOKENIZERS_PARALLELISM=false
QDRANT_URL={{ memory_worker_qdrant_url }}
QDRANT_API_KEY={{ memory_worker_qdrant_api_key }}
QDRANT_TIMEOUT={{ memory_worker_qdrant_timeout }}
QDRANT_VERIFY_TLS={{ 'true' if memory_worker_qdrant_verify_tls | bool else 'false' }}
# LiteLLM proxy — consumed by consolidate_rex.py (synthèses REX hebdo, modèle
# économique, gardé par le cap budget LiteLLM). Fichier 0600 -> clé jamais dans ps.
LITELLM_BASE_URL={{ memory_worker_litellm_base_url }}
LITELLM_API_KEY={{ memory_worker_litellm_api_key }}
LITELLM_MODEL={{ memory_worker_consolidate_model }}
# Identity + repo list — consumed by run-and-report.sh to send a "start" event
# to n8n so the Telegram bot can show live worker state (push-only heartbeat).
MEMORY_WORKER_HOST_ORIGIN={{ memory_worker_host_origin }}
MEMORY_WORKER_REPOS={{ memory_worker_sources | map(attribute='name') | join(',') }}
# FIX B (audit mémoire 2026-07-17) : reranker bge-reranker-v2-m3 câblé (mcp_search.py
# + search_memory.py) mais OFF par défaut (RERANK_ENABLED absent -> false). Benchmark
# Pi réel (RPi5, nice -19, 27 requêtes, modèle chargé une fois, 20 candidats) :
# +9.8s médiane / +13.6s max PAR REQUÊTE en sus du RRF (~0.6s) -> trop lent pour R0
# interactif (budget ~3-5s). Le repo HF par défaut de rerank.py (BAAI/bge-reranker-v2-m3)
# n'expose AUCUN artefact ONNX -> override obligatoire vers une conversion ONNX,
# sinon le flag ON resterait un no-op silencieux (fail-open, warning stderr).
MEMORY_RERANK_MODEL_ID={{ memory_worker_rerank_model_id | default('onnx-community/bge-reranker-v2-m3-ONNX') }}
{% if memory_worker_rerank_enabled | default(false) | bool %}
RERANK_ENABLED=true
{% else %}
# RERANK_ENABLED=true   # décommenter (ou memory_worker_rerank_enabled: true) pour activer
{% endif %}
# Restauration recall@1 (2026-07-17) : DBSF par défaut (natif Qdrant, zéro coût de
# latence, +3 à +4 pts recall@1 vs RRF mesuré golden 76 questions, reproductible).
# Rollback instantané : MEMORY_FUSION_MODE=rrf (ou memory_worker_fusion_mode: rrf).
MEMORY_FUSION_MODE={{ memory_worker_fusion_mode | default('dbsf') }}
