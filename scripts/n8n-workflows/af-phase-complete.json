          "parameters": [
            {
              "name": "x-af-secret",
              "value": "={{ $env.AF_WEBHOOK_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ source: 'phase-complete', project_name: $('Parse Phase Data').first().json.project_name, phase_number: $('Parse Phase Data').first().json.phase_number, phase_name: $('Parse Phase Data').first().json.phase_name, text: 'Phase ' + $('Parse Phase Data').first().json.phase_number + ' (' + $('Parse Phase Data').first().json.phase_name + ') for ' + $('Parse Phase Data').first().json.project_name + ': ' + $('Parse Phase Data').first().json.summary, metadata: { duration_min: $('Parse Phase Data').first().json.duration_min, files_changed: $('Parse Phase Data').first().json.files_changed } }) }}",
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "no-op-skip",
      "name": "No Decisions",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        2890,
        400
      ],
      "parameters": {}
    },
    {
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
