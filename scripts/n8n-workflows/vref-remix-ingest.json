    {
      "parameters": {
        "jsCode": "const ctx = $('Extract content_id').first().json;\ntry {\n  await $http.request({\n    method: 'POST',\n    url: 'http://javisi_n8n:5678/webhook/cf-brief-to-concept',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({\n      secret: $env.N8N_WEBHOOK_SECRET,\n      content_id: ctx.content_id,\n      title: ctx.title,\n      format: ctx.format || 'story',\n      brief: ctx.brief\n    })\n  });\n  return [{ json: { cf_triggered: true, content_id: ctx.content_id } }];\n} catch(e) {\n  return [{ json: { cf_triggered: false, cf_error: e.message } }];\n}"
      },
