      "from": {
        "blockId": "b_init_idx"
      },
      "to": {
        "groupId": "g_sop_loop"
      }
    },
    {
      "id": "edge_ack_cond",
      "from": {
        "blockId": "b_ack"
      },
      "to": {
        "groupId": "g_sop_cond"
      }
    },
    {
      "id": "edge_cond_true",
      "from": {
        "blockId": "b_cond"
      },
      "to": {
        "groupId": "g_valid"
      }
    },
    {
      "id": "edge_cond_false",
      "from": {
        "blockId": "b_cond"
      },
      "to": {
        "groupId": "g_sop_update"
      }
    },
    {
      "id": "edge_valid_comment",
      "from": {
        "blockId": "b_resolution"
      },
      "to": {
        "groupId": "g_comment"
      }
    },
