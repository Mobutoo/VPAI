# {{ ansible_managed }}
# Content Factory v2 (M0) — variante Sese-AI (FRUGAL).
# RÉUTILISE l'infra prod : Postgres `javisi_postgresql` (PG18.4) + réseaux externes
# `javisi_backend`/`javisi_frontend`. Routing via `javisi_caddy` (vhost hors de ce compose).
# 4 services : Temporal (auto-setup), API (FastAPI), Conductor (worker Temporal),
# Render (worker Temporal V-2 découpe — ffmpeg+PySceneDetect) ; + Studio optionnel.

services:
  cf-temporal:
    image: {{ cf_temporal_image }}
    container_name: cf-temporal
    restart: unless-stopped
    environment:
      # auto-setup crée temporal + temporal_visibility + le namespace, DANS javisi_postgresql.
      DB: postgres12                       # nom du plugin driver (valide PG12..18), pas une version
      DB_PORT: "5432"                       # OBLIGATOIRE : wait_for_postgres fait `nc -z $SEEDS $DB_PORT` ; vide = boucle infinie
      POSTGRES_SEEDS: {{ cf_pg_host }}
      POSTGRES_USER: {{ cf_pg_admin_user }}   # auto-setup crée temporal/temporal_visibility → superuser requis (cf_app = DSN cf-api uniquement)
      POSTGRES_PWD: {{ postgresql_password }}
      DBNAME: {{ cf_temporal_db_name }}
      VISIBILITY_DBNAME: {{ cf_temporal_visibility_db_name }}
      DEFAULT_NAMESPACE: {{ cf_temporal_namespace }}
      ENABLE_ES: "false"
    networks:
      - {{ cf_backend_network }}           # accès javisi_postgresql + inter-services
    mem_limit: {{ cf_temporal_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      # tctl présent dans l'image auto-setup (vérifié live 2026-07-02 : /usr/local/bin/tctl).
      # PIÈGE : l'entrypoint binde le frontend sur l'IP du conteneur (BIND_ON_IP par défaut
      # = getent hosts $(hostname)), PAS sur 127.0.0.1 → cibler $(hostname -i):7233.
      # `tctl cluster health` → rc 0 + "WorkflowService: SERVING" quand le frontend répond.
      test: ["CMD-SHELL", "tctl --address \"$(hostname -i):7233\" cluster health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  cf-api:
    build:
      context: {{ cf_src_dir }}/apps/api
      dockerfile: Dockerfile
    container_name: cf-api
    restart: unless-stopped
    env_file:
      - {{ cf_config_dir }}/api.env
    volumes:
      # S2 : persistance de la sortie vidéo (worker GPU → upload → volume Sese,
      # PAS d'objectstore S3). Monté sur CF_MEDIA_DIR (api.env.j2) ; nommé (pas de
      # bind-host) → survit à un recreate du conteneur, backup via le volume Docker.
      - cf_media:/media
    networks:
      - {{ cf_backend_network }}           # joindre javisi_postgresql
      - {{ cf_frontend_network }}          # être routé par javisi_caddy
    mem_limit: {{ cf_api_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "python3 -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:8000/health\")'"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s

  cf-conductor:
    build:
      # Contexte = RACINE du repo : le Dockerfile (depuis 8e06e2e) COPY services/conductor/,
      # services/plane-adapter/ ET packages/providers/ (activities_gpu importe providers) —
      # chemins relatifs à la racine, pas à services/. Corrigé 2026-07-06 (ancien
      # context=services/ + dockerfile=conductor/Dockerfile → COPY services/conductor cassé).
      context: {{ cf_src_dir }}
      dockerfile: services/conductor/Dockerfile
    container_name: cf-conductor
    restart: unless-stopped
    env_file:
      - {{ cf_config_dir }}/conductor.env
    networks:
      - {{ cf_backend_network }}           # joindre cf-temporal + cf-api (+ egress Plane)
      # M1 GPU dispatch (2026-07-07) : cf_backend_network est `internal:true` (aucun
      # egress). Le conducteur DOIT joindre le frontend (comme cf-api) pour atteindre
      # (1) RunPod api.runpod.ai/v2 sur INTERNET (POST /run dispatch) et (2) PodPilot
      # sur le MESH Tailscale waza 100.64.0.1 (GET /v1/resolve) — les deux echouent
      # depuis backend seul (« Network unreachable » / DNS fail, constate au 1er e2e).
      - {{ cf_frontend_network }}
    mem_limit: {{ cf_conductor_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    depends_on:
      cf-temporal:
        condition: service_healthy         # healthcheck tctl ci-dessus (audit H7)
      cf-api:
        condition: service_healthy

  # V-2 découpe → plans : worker Temporal task-queue cf-render (ffmpeg +
  # PySceneDetect, 1 job à la fois). Backend SEUL : il ne parle qu'à cf-temporal
  # et cf-api (write-back) — aucun egress internet/mesh, contrairement au
  # conducteur. Monte cf_media en RW (mêmes chemins que cf-api, uid 10001).
  cf-render:
    build:
      context: {{ cf_src_dir }}
      dockerfile: services/render/Dockerfile
    container_name: cf-render
    restart: unless-stopped
    env_file:
      - {{ cf_config_dir }}/render.env
    volumes:
      - cf_media:/media
    networks:
      - {{ cf_backend_network }}
      # V5-B : egress mesh (POST jobs Remotion waza:3200) — même fix que
      # cf-conductor en M1 (javisi_backend est internal:true = zéro egress).
      - {{ cf_frontend_network }}
    mem_limit: {{ cf_render_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    depends_on:
      cf-temporal:
        condition: service_healthy
      cf-api:
        condition: service_healthy

{% if studio_enabled | default(false) | bool %}
  # Studio Web (atelier Next.js statique) — build-on-host, servi par nginx, routé
  # par javisi_caddy sur {{ caddy_studio_domain }}. Ne parle qu'à javisi_frontend :
  # le navigateur appelle cf-api directement (NEXT_PUBLIC_CF_API_URL inliné au build).
  cf-studio:
    build:
      context: {{ cf_src_dir }}/apps/studio
      dockerfile: Dockerfile
      args:
        NEXT_PUBLIC_CF_API_URL: "https://{{ caddy_cf_domain }}"
    container_name: cf-studio
    restart: unless-stopped
    networks:
      - {{ cf_frontend_network }}          # routé par javisi_caddy
    mem_limit: {{ cf_studio_mem_limit | default('128m') }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      # 127.0.0.1 explicite : `localhost` résout ::1 en premier dans le conteneur
      # alors que nginx n'écoute qu'en IPv4 -> faux unhealthy permanent.
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:80/ >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 15s
{% endif %}

volumes:
  # S2 : sortie vidéo persistée (cf-api, /media) — volume Docker NOMMÉ, créé par
  # ce compose (pas external, contrairement aux réseaux ci-dessous).
  cf_media:

networks:
  # Réseaux prod pré-existants — jamais créés par ce compose.
  {{ cf_backend_network }}:
    external: true
  {{ cf_frontend_network }}:
    external: true
