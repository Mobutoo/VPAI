# {{ ansible_managed }}
# Content Factory API (apps/api — FastAPI, app.main:app, port 8000) — variante Sese.
# Postgres prod réutilisé : javisi_postgresql. Mot de passe PARTAGÉ (CLAUDE.md): postgresql_password.
# DSN applicatif = cf_app (audit 2026-07-02 C2 : plus de superuser dans le DSN).
CF_DATABASE_URL=postgresql+psycopg://{{ cf_pg_user }}:{{ postgresql_password }}@{{ cf_pg_host }}:5432/{{ cf_db_name }}
# Bearer requis sur les routes REST (audit C2/A1.2). Source vault: vault_cf_api_token.
CF_API_TOKEN={{ cf_api_token }}
CF_ENV=prod
# Strangler compat (cutover n8n → API) : la façade /compat/* rejoue la validation
# dual-secret v1 (header x-webhook-secret OU body.secret). MÊME secret que côté n8n.
# Absent → /compat/* renvoie 401 (fail-closed). Source vault: vault_n8n_webhook_secret.
N8N_WEBHOOK_HMAC_SECRET={{ n8n_webhook_secret }}
