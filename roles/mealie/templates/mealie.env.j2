# {{ ansible_managed }}
# Mealie Environment — managed by Ansible

PUID=1000
PGID=1000
TZ={{ timezone | default('Europe/Paris') }}

# Database (shared PostgreSQL instance)
DB_ENGINE=postgres
POSTGRES_USER={{ mealie_db_user }}
POSTGRES_PASSWORD={{ postgresql_password }}
POSTGRES_SERVER=postgresql
POSTGRES_PORT=5432
POSTGRES_DB={{ mealie_db_name }}

# Application
BASE_URL=https://{{ caddy_mealie_domain }}
API_PORT={{ mealie_web_port }}
ALLOW_SIGNUP=false
MAX_WORKERS=1
WEB_CONCURRENCY=1
TOKEN_TIME=720
