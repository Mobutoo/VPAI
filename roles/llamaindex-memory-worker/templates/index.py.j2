#!/usr/bin/env python3
"""Incremental local memory indexing for Waza -> Qdrant (collection memory_v2).

La logique d'ingestion canonique (taxonomie wing/room, classify_*, build_payload,
chunking, encodeur, struct_meta) est importée de `memory_core` — module PARTAGÉ
avec le batch pod, garantissant une parité STRICTE des payloads / node_id. Ce
fichier ne contient plus que l'orchestration propre au worker : lock, state,
spool, client Qdrant, vector store, CLI, run-report.
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import sys
import uuid
from datetime import datetime, timezone
from logging.handlers import RotatingFileHandler
from pathlib import Path
from typing import Any, Iterable

import yaml
from llama_index.core.schema import TextNode
from qdrant_client import QdrantClient
from qdrant_client.http import models as rest
from llama_index.vector_stores.qdrant import QdrantVectorStore

# --- Source unique de vérité partagée worker <-> batch pod (parité) ----------
# (schema_version / chunking_strategy_version sont posés par build_payload.)
from memory_core import (
    EmbeddingGemmaEncoder,
    build_chunks,
    classify_doc_kind,
    classify_room,
    extract_structural_meta,
    extract_topic,
    git_commit_sha,
    load_wing_room_lookup,
    ref_doc_id,
    resolve_source,
    sha256_file,
    sha256_text,
    to_text_nodes,
    utcnow_iso,
)

REPORT_SCHEMA_VERSION = "memory-worker-report-v1"
LOG = logging.getLogger("memory_worker")


def load_yaml(path: Path) -> dict[str, Any]:
    with path.open("r", encoding="utf-8") as handle:
        return yaml.safe_load(handle) or {}


def load_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def dump_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2, ensure_ascii=False, sort_keys=True)


def ensure_lock(lock_path: Path) -> None:
    try:
        fd = os.open(str(lock_path), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
    except FileExistsError as exc:
        try:
            pid = int(lock_path.read_text().strip() or "0")
        except Exception:
            pid = 0
        alive = False
        if pid > 0:
            try:
                os.kill(pid, 0); alive = True
            except ProcessLookupError:
                alive = False
            except PermissionError:
                alive = True
        if alive:
            raise RuntimeError(f"lock held by live pid {pid}: {lock_path}") from exc
        LOG.warning("stale lock (pid=%s dead) removed — reclaiming: %s", pid, lock_path)
        lock_path.unlink(missing_ok=True)  # stale → reclaim
        fd = os.open(str(lock_path), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        handle.write(str(os.getpid()))


def release_lock(lock_path: Path) -> None:
    try:
        lock_path.unlink()
    except FileNotFoundError:
        pass


def check_loadavg(threshold: float) -> None:
    load1, _, _ = os.getloadavg()
    if load1 > threshold:
        raise RuntimeError(f"loadavg too high: {load1:.2f} > {threshold:.2f}")


def iter_repo_files(repo_root: Path, include_ext: set[str], exclude_dirs: set[str], max_file_bytes: int) -> Iterable[Path]:
    for current_root, dirs, files in os.walk(repo_root):
        dirs[:] = [dirname for dirname in dirs if dirname not in exclude_dirs]
        current_path = Path(current_root)
        for filename in files:
            path = current_path / filename
            if path.suffix.lower() not in include_ext:
                continue
            try:
                if path.stat().st_size > max_file_bytes:
                    continue
            except FileNotFoundError:
                continue
            yield path


def find_repo_root(target: Path, repo_roots: list[Path]) -> Path | None:
    resolved = target.resolve()
    for repo_root in repo_roots:
        try:
            resolved.relative_to(repo_root.resolve())
            return repo_root
        except ValueError:
            continue
    return None


def iter_target_files(
    args: argparse.Namespace,
    repo_roots: list[Path],
    include_ext: set[str],
    exclude_dirs: set[str],
    max_file_bytes: int,
) -> Iterable[tuple[Path, Path]]:
    selected_roots = repo_roots
    if args.repo:
        requested = set(args.repo)
        selected_roots = [root for root in repo_roots if root.name in requested]

    if args.path:
        seen: set[tuple[str, str]] = set()
        for raw in args.path:
            target = Path(raw).expanduser()
            if not target.exists():
                LOG.warning("target path missing: %s", target)
                continue
            repo_root = find_repo_root(target, selected_roots)
            if repo_root is None:
                LOG.warning("path outside configured repos: %s", target)
                continue
            if target.is_file():
                rel = target.relative_to(repo_root).as_posix()
                cache_key = (repo_root.name, rel)
                if cache_key in seen:
                    continue
                seen.add(cache_key)
                if target.suffix.lower() not in include_ext:
                    continue
                try:
                    if target.stat().st_size > max_file_bytes:
                        continue
                except FileNotFoundError:
                    continue
                yield repo_root, target
                continue
            for path in iter_repo_files(target, include_ext, exclude_dirs, max_file_bytes):
                rel = path.relative_to(repo_root).as_posix()
                cache_key = (repo_root.name, rel)
                if cache_key in seen:
                    continue
                seen.add(cache_key)
                yield repo_root, path
        return

    for repo_root in selected_roots:
        for path in iter_repo_files(repo_root, include_ext, exclude_dirs, max_file_bytes):
            yield repo_root, path


def state_key(repo: str, relative_path: str) -> str:
    return f"{repo}:{relative_path}"



def build_qdrant_client(config: dict[str, Any]) -> QdrantClient:
    verify = str(os.getenv("QDRANT_VERIFY_TLS", config.get("qdrant_verify_tls", True))).lower() == "true"
    return QdrantClient(
        url=os.getenv("QDRANT_URL", config["qdrant_url"]),
        api_key=os.getenv("QDRANT_API_KEY"),
        timeout=int(os.getenv("QDRANT_TIMEOUT", config["qdrant_timeout"])),
        verify=verify,
    )


def build_vector_store(client: QdrantClient, config: dict[str, Any]) -> QdrantVectorStore:
    schema_map = {
        "keyword": rest.PayloadSchemaType.KEYWORD,
    }
    payload_indexes = []
    for item in config.get("payload_indexes", []):
        payload_indexes.append(
            {
                "field_name": item["field_name"],
                "field_schema": schema_map[item["field_schema"]],
            }
        )
    return QdrantVectorStore(
        collection_name=config["collection_name"],
        client=client,
        index_doc_id=True,
        payload_indexes=payload_indexes,
    )


def merge_source_roots(config: dict[str, Any], sources_path: str | None) -> list[str]:
    roots: list[str] = []
    if sources_path:
        path = Path(sources_path).expanduser()
        if path.exists():
            payload = load_yaml(path)
            for source in payload.get("sources", []):
                if isinstance(source, str):
                    roots.append(source)
                    continue
                if isinstance(source, dict) and source.get("root"):
                    roots.append(str(source["root"]))
    if not roots:
        roots = [str(path) for path in config.get("repos", [])]
    deduped: list[str] = []
    seen: set[str] = set()
    for raw in roots:
        key = str(Path(raw).expanduser())
        if key in seen:
            continue
        seen.add(key)
        deduped.append(raw)
    return deduped


def apply_sources_config(config: dict[str, Any], args: argparse.Namespace) -> None:
    configured_path = config.get("paths", {}).get("sources_file")
    sources_path = args.sources or configured_path
    config["repos"] = merge_source_roots(config, sources_path)
    config["sources_file"] = sources_path or ""


def list_repo_roots(config: dict[str, Any]) -> list[Path]:
    # Contrat canonique (parite worker<->pod, BLOCKER #1) : chaque source =
    # UN arbre unique. PAS d'expansion des repos git imbriques — sinon le worker
    # produirait repo="<nested>"/rel="x.md" alors que le pod produit repo="DOCS"/
    # rel="<nested>/x.md", divergeant sur ref_doc_id, node_id et classify_room.
    # Les repos imbriques (flash-infra dans flash-studio, *-docs dans DOCS) sont
    # couverts comme sous-dossiers de leur source parente.
    roots = []
    for raw in config["repos"]:
        path = Path(raw).expanduser()
        if not path.exists():
            continue
        roots.append(path)
    return roots


def load_spool(spool_dir: Path) -> list[dict[str, str]]:
    pending = []
    for path in sorted(spool_dir.glob("*.json")):
        payload = load_json(path)
        payload["_spool_path"] = str(path)
        pending.append(payload)
    return pending


def add_to_spool(spool_dir: Path, repo: str, relative_path: str) -> None:
    spool_path = spool_dir / f"{sha256_text(f'{repo}:{relative_path}')}.json"
    if spool_path.exists():
        return
    dump_json(
        spool_path,
        {
            "repo": repo,
            "relative_path": relative_path,
            "queued_at": utcnow_iso(),
        },
    )


def remove_from_spool(entry: dict[str, str]) -> None:
    spool_path = entry.get("_spool_path")
    if spool_path:
        Path(spool_path).unlink(missing_ok=True)


def short_error_message(exc: Exception) -> str:
    message = f"{exc.__class__.__name__}: {exc}"
    return message[:300]


def count_spool_entries(spool_dir: Path) -> int:
    return sum(1 for _ in spool_dir.glob("*.json"))


def emit_run_report(report: dict[str, Any], report_path: str | None) -> None:
    rendered = json.dumps(report, ensure_ascii=False, sort_keys=True)
    if report_path:
        path = Path(report_path)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(rendered + "\n", encoding="utf-8")
    print(rendered)


def should_process(path: Path, repo_root: Path, state: dict[str, Any], mode: str) -> tuple[bool, dict[str, Any], str]:
    relative_path = path.relative_to(repo_root).as_posix()
    repo = repo_root.name
    key = state_key(repo, relative_path)
    stat = path.stat()
    current = {
        "size": stat.st_size,
        "mtime": int(stat.st_mtime),
    }
    previous = state.get(key)
    if mode == "full" or previous is None:
        return True, current, relative_path
    if previous.get("size") != current["size"] or previous.get("mtime") != current["mtime"]:
        return True, current, relative_path
    return False, current, relative_path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Index local repos into Qdrant memory_v1.")
    parser.add_argument("--config", required=True, help="Path to worker config file.")
    parser.add_argument("--sources", help="Optional source roots YAML file. Defaults to config paths.sources_file.")
    parser.add_argument("--mode", choices=["full", "incremental"], default="incremental")
    parser.add_argument("--gc", action="store_true", help="Delete state entries whose files disappeared.")
    parser.add_argument("--dry-run", action="store_true", help="Show planned actions without touching Qdrant.")
    parser.add_argument("--preflight-only", action="store_true", help="Run connectivity and environment checks only.")
    parser.add_argument("--repo", action="append", default=[], help="Restrict processing to a configured repo name.")
    parser.add_argument("--path", action="append", default=[], help="Restrict processing to one file or subdirectory.")
    parser.add_argument("--max-files", type=int, default=0, help="Maximum number of candidate files to process.")
    parser.add_argument("--report-path", help="Write a machine-readable JSON report to this path.")
    return parser.parse_args()


def configure_logging(log_dir: Path) -> None:
    log_dir.mkdir(parents=True, exist_ok=True)
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
        handlers=[
            logging.StreamHandler(sys.stdout),
            RotatingFileHandler(
                log_dir / "memory-worker.log",
                maxBytes=5 * 1024 * 1024,
                backupCount=3,
            ),
        ],
    )


def batched(items: list[Any], batch_size: int) -> Iterable[list[Any]]:
    for index in range(0, len(items), batch_size):
        yield items[index:index + batch_size]


def hf_cache_ready(config: dict[str, Any]) -> bool:
    model_name = config["embedding"]["model_name"]
    cache_key = f"models--{model_name.replace('/', '--')}"
    return (Path(config["paths"]["hf_home"]) / cache_key).exists()


def run_preflight(args: argparse.Namespace, config: dict[str, Any], repo_roots: list[Path]) -> bool:
    hf_token_present = bool(os.getenv("HF_TOKEN") or os.getenv("HUGGINGFACE_HUB_TOKEN"))
    LOG.info("preflight repo_roots=%s repos=%s", len(repo_roots), [root.name for root in repo_roots])
    LOG.info("preflight model_cache=%s hf_token_present=%s", hf_cache_ready(config), hf_token_present)
    if not repo_roots:
        raise RuntimeError("no configured repos found")
    if args.repo:
        requested = set(args.repo)
        found = {root.name for root in repo_roots}
        missing = sorted(requested - found)
        if missing:
            raise RuntimeError(f"requested repo(s) not found: {', '.join(missing)}")
    client = build_qdrant_client(config)
    collections = client.get_collections()
    LOG.info("preflight qdrant_ok collections=%s", len(collections.collections))
    return True


def selected_repo_names(args: argparse.Namespace, repo_roots: list[Path]) -> list[str]:
    if args.repo:
        requested = set(args.repo)
        return sorted(root.name for root in repo_roots if root.name in requested)
    return sorted(root.name for root in repo_roots)


def main() -> int:
    args = parse_args()
    config = load_yaml(Path(args.config))
    apply_sources_config(config, args)
    configure_logging(Path(config["paths"]["log_dir"]))
    started_dt = datetime.now(timezone.utc)
    run_id = f"{started_dt.strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:8]}"
    lock_path = Path(config["paths"]["state_dir"]) / "index.lock"
    state_path = Path(config["paths"]["state_dir"]) / "memory_state.json"
    spool_dir = Path(config["paths"]["spool_dir"])
    qdrant_reachable = False
    repo_roots: list[Path] = []
    report_errors: list[str] = []
    attempted_files = 0
    indexed_files = 0
    indexed_chunks = 0
    skipped_count = 0
    error_count = 0
    exit_code = 1
    report_repo: str | None = None
    report_repos: list[str] = []
    acquired = False

    try:
        ensure_lock(lock_path)
        acquired = True
        check_loadavg(float(config["limits"]["loadavg_threshold"]))
        state = load_json(state_path)
        include_ext = set(config["filters"]["include_extensions"])
        exclude_dirs = set(config["filters"]["exclude_dirs"])
        repo_roots = list_repo_roots(config)
        report_repos = selected_repo_names(args, repo_roots)
        report_repo = report_repos[0] if len(report_repos) == 1 else None
        progress_every = max(1, int(config["limits"].get("progress_every", 10)))
        LOG.info(
            "run started run_id=%s mode=%s dry_run=%s gc=%s repo_filters=%s path_filters=%s max_files=%s",
            run_id,
            args.mode,
            args.dry_run,
            args.gc,
            args.repo,
            args.path,
            args.max_files,
        )
        qdrant_reachable = run_preflight(args, config, repo_roots)
        if args.preflight_only:
            LOG.info("preflight completed")
            exit_code = 0
            return exit_code
        encoder = EmbeddingGemmaEncoder(
            model_name=config["embedding"]["model_name"],
            normalize_embeddings=bool(config["embedding"]["normalize_embeddings"]),
        )

        client = None if args.dry_run else build_qdrant_client(config)
        vector_store = None if args.dry_run else build_vector_store(client, config)
        processed_keys: set[str] = set()
        had_errors = False

        # Lookup wing/room (autorite unique partagee avec le pod). Charge depuis
        # le sources.yml rendu (emet desormais `wing` par source).
        wing_lookup = load_wing_room_lookup(config["sources_file"])

        pending_spool = load_spool(spool_dir)
        if pending_spool:
            LOG.info("retrying %s spooled entries", len(pending_spool))

        for entry in pending_spool:
            repo_name = entry["repo"]
            relative_path = entry["relative_path"]
            matching_root = next((root for root in repo_roots if root.name == repo_name), None)
            if matching_root is None:
                continue
            target = matching_root / relative_path
            if not target.exists():
                remove_from_spool(entry)
                continue
            try:
                chunk_count = process_file(
                    args=args,
                    config=config,
                    state=state,
                    encoder=encoder,
                    vector_store=vector_store,
                    repo_root=matching_root,
                    path=target,
                    processed_keys=processed_keys,
                    spool_dir=spool_dir,
                    wing_lookup=wing_lookup,
                )
            except Exception as exc:  # noqa: BLE001
                had_errors = True
                error_count += 1
                report_errors.append(f"spool:{repo_name}:{relative_path}: {short_error_message(exc)}")
                LOG.exception("spool retry failed repo=%s relative_path=%s", repo_name, relative_path)
                continue
            remove_from_spool(entry)
            if chunk_count > 0:
                indexed_files += 1
                indexed_chunks += chunk_count
            else:
                skipped_count += 1

        for repo_root, path in iter_target_files(
            args=args,
            repo_roots=repo_roots,
            include_ext=include_ext,
            exclude_dirs=exclude_dirs,
            max_file_bytes=int(config["limits"]["max_file_bytes"]),
        ):
            repo_name = repo_root.name
            if args.max_files > 0 and attempted_files >= args.max_files:
                LOG.info("max-files limit reached: %s", args.max_files)
                break
            attempted_files += 1
            if attempted_files == 1 or attempted_files % progress_every == 0:
                LOG.info(
                    "progress candidates_seen=%s indexed_files=%s indexed_chunks=%s skipped=%s errors=%s",
                    attempted_files,
                    indexed_files,
                    indexed_chunks,
                    skipped_count,
                    error_count,
                )
            if args.max_files > 0 and attempted_files == args.max_files:
                LOG.info("processing candidate %s/%s", attempted_files, args.max_files)
            else:
                LOG.debug("processing candidate %s", attempted_files)
            should_run, _, relative_path = should_process(path, repo_root, state, args.mode)
            key = state_key(repo_name, relative_path)
            if key in processed_keys:
                skipped_count += 1
                continue
            if not should_run:
                processed_keys.add(key)
                skipped_count += 1
                continue
            try:
                chunk_count = process_file(
                    args=args,
                    config=config,
                    state=state,
                    encoder=encoder,
                    vector_store=vector_store,
                    repo_root=repo_root,
                    path=path,
                    processed_keys=processed_keys,
                    spool_dir=spool_dir,
                    wing_lookup=wing_lookup,
                )
            except Exception as exc:  # noqa: BLE001
                had_errors = True
                error_count += 1
                report_errors.append(f"candidate:{repo_name}:{relative_path}: {short_error_message(exc)}")
                LOG.exception("candidate failed repo=%s relative_path=%s", repo_name, relative_path)
                continue
            if chunk_count > 0:
                indexed_files += 1
                indexed_chunks += chunk_count
            else:
                skipped_count += 1

        if args.gc:
            gc_missing_entries(args, state, vector_store, repo_roots)

        dump_json(state_path, state)
        LOG.info(
            "memory worker completed attempted_files=%s indexed_files=%s indexed_chunks=%s skipped=%s errors=%s",
            attempted_files,
            indexed_files,
            indexed_chunks,
            skipped_count,
            error_count,
        )
        exit_code = 1 if had_errors else 0
        return exit_code
    except Exception as exc:  # noqa: BLE001
        error_count += 1
        report_errors.append(short_error_message(exc))
        LOG.exception("memory worker failed: %s", exc)
        exit_code = 1
        return exit_code
    finally:
        if acquired:
            release_lock(lock_path)
        duration_s = (datetime.now(timezone.utc) - started_dt).total_seconds()
        try:
            loadavg_1min = os.getloadavg()[0]
        except (OSError, AttributeError):
            loadavg_1min = None
        report = {
            "report_schema_version": REPORT_SCHEMA_VERSION,
            "run_id": run_id,
            "repo": report_repo,
            "repos": report_repos,
            "mode": args.mode,
            "gc_enabled": args.gc,
            "dry_run": args.dry_run,
            "started_at": started_dt.isoformat(),
            "duration_sec": round(duration_s, 2),
            "attempted_files": attempted_files,
            "indexed_files": indexed_files,
            "indexed_chunks": indexed_chunks,
            "skipped_files": skipped_count,
            "errors": report_errors[:20],
            "spool_size": count_spool_entries(spool_dir),
            "qdrant_reachable": qdrant_reachable,
            "exit_code": exit_code,
            "collection_name": config.get("collection_name"),
            "embedding_model": config.get("embedding", {}).get("model_name"),
            "worker_version": "{{ memory_worker_version }}",
            "host_origin": "{{ memory_worker_host_origin }}",
            "indexed_points": indexed_chunks,
            "loadavg_1min": round(loadavg_1min, 2) if loadavg_1min is not None else None,
        }
        emit_run_report(report, args.report_path)


def process_file(
    args: argparse.Namespace,
    config: dict[str, Any],
    state: dict[str, Any],
    encoder: EmbeddingGemmaEncoder,
    vector_store: QdrantVectorStore | None,
    repo_root: Path,
    path: Path,
    processed_keys: set[str],
    spool_dir: Path,
    wing_lookup: dict[Path, dict[str, str]],
) -> int:
    # (repo, wing, relative_path) via l'autorite unique memory_core.resolve_source
    # (contrat canonique partage avec le pod). repo_root reste l'ancre git/state.
    resolved = resolve_source(path, wing_lookup)
    if resolved is None:
        LOG.warning("file outside any wing-mapped source, skipped: %s", path)
        return 0
    repo, wing, relative_path = resolved
    room = classify_room(wing, relative_path)
    key = state_key(repo, relative_path)
    processed_keys.add(key)

    try:
        content = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        LOG.info("skip non-utf8 file %s", path)
        return 0

    chunks = build_chunks(
        path=Path(relative_path),
        text=content,
        chunk_size=int(config["limits"]["chunk_size"]),
        overlap=int(config["limits"]["chunk_overlap"]),
        max_chunks=int(config["limits"]["max_chunks_per_file"]),
    )
    if not chunks:
        return 0

    topic = extract_topic(repo, Path(relative_path), content, classify_doc_kind(Path(relative_path)))
    content_hash = sha256_file(path)
    git_sha = git_commit_sha(repo_root, path)
    ref_id = ref_doc_id(repo, relative_path)
    struct_meta = extract_structural_meta(Path(relative_path), content)
    nodes = to_text_nodes(
        repo=repo,
        path=Path(relative_path),
        relative_path=relative_path,
        wing=wing,
        room=room,
        topic=topic,
        content_hash=content_hash,
        git_sha=git_sha,
        chunks=chunks,
        struct_meta=struct_meta,
        embedding_model="{{ memory_worker_embedding_model }}",
        embedding_dim={{ memory_worker_embedding_dim }},
        host_origin="{{ memory_worker_host_origin }}",
    )
    batch_size = int(config["limits"]["batch_size"])
    prepared_nodes: list[TextNode] = []
    for node_batch in batched(nodes, batch_size):
        embeddings = encoder.encode_documents([(node.metadata["title"], node.text) for node in node_batch])
        for node, embedding in zip(node_batch, embeddings, strict=True):
            node.embedding = embedding
            prepared_nodes.append(node)

    stat = path.stat()
    next_state = {
        "size": stat.st_size,
        "mtime": int(stat.st_mtime),
        "content_hash": content_hash,
        "git_commit_sha": git_sha,
        "ref_doc_id": ref_id,
        "doc_kind": classify_doc_kind(Path(relative_path)),
        "last_indexed_at": utcnow_iso(),
    }

    if args.dry_run:
        LOG.info("would index %s (%s chunks)", relative_path, len(prepared_nodes))
        state[key] = next_state
        return len(prepared_nodes)

    try:
        vector_store.delete(ref_id)
        for node_batch in batched(prepared_nodes, batch_size):
            vector_store.add(node_batch)
    except Exception as exc:  # noqa: BLE001
        LOG.exception("failed to index %s: %s", relative_path, exc)
        add_to_spool(spool_dir, repo, relative_path)
        raise

    state[key] = next_state
    LOG.info("indexed %s (%s chunks)", relative_path, len(prepared_nodes))
    return len(prepared_nodes)


def gc_missing_entries(
    args: argparse.Namespace,
    state: dict[str, Any],
    vector_store: QdrantVectorStore | None,
    repo_roots: list[Path],
) -> None:
    if args.path:
        LOG.info("skipping gc because path filters are active")
        return

    existing_roots = {root.name: root for root in repo_roots}
    selected_repos = {root.name for root in repo_roots}
    if args.repo:
        selected_repos &= set(args.repo)
    to_delete = []
    for key, entry in state.items():
        repo_name, relative_path = key.split(":", 1)
        if selected_repos and repo_name not in selected_repos:
            continue
        repo_root = existing_roots.get(repo_name)
        if repo_root is not None and (repo_root / relative_path).exists():
            continue
        to_delete.append((key, entry))

    for key, entry in to_delete:
        if args.dry_run:
            LOG.info("would delete orphaned ref_doc_id=%s", entry["ref_doc_id"])
            state.pop(key, None)
            continue
        if vector_store is not None:
            vector_store.delete(entry["ref_doc_id"])
        state.pop(key, None)
        LOG.info("deleted orphaned ref_doc_id=%s", entry["ref_doc_id"])


if __name__ == "__main__":
    sys.exit(main())
