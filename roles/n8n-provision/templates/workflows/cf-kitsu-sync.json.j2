      "id": "cfks-0001-0000-0000-0000-000000000004",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [920, 380]
    },
    {
      "parameters": {
        "jsCode": "// Update Kitsu task status for the given content and step\n// Maps pipeline status to Kitsu task status\nconst { content_id, data, kitsu_token } = $input.first().json;\n\n// Status mapping: pipeline -> Kitsu status name\nconst STATUS_MAP = {\n  'wip':         'WIP',\n  'done':        'Done',\n  'retake':      'Retake',\n  'invalidated': 'Retake',\n  'generating':  'Generating',\n  'todo':        'Todo'\n};\n\nconst steps    = Array.isArray(data.steps) ? data.steps : [data.step];\nconst status   = data.status || 'wip';\nconst comment  = data.comment || `Status updated to ${status}`;\nconst kitsuStatus = STATUS_MAP[status] || 'WIP';\n\n// Fetch tasks for this content (shot)\nconst tasksResp = await $http.request({\n  method: 'GET',\n  url: `http://kitsu:80/api/data/tasks?project_id=${data.project_id || '19b9faf4-f7c4-4829-9739-cbf7c3181941'}`,\n  headers: {\n    'Authorization': `Bearer ${kitsu_token}`,\n    'Content-Type': 'application/json'\n  }\n});\n\nconst allTasks = tasksResp.data || tasksResp || [];\n\n// Find tasks related to content_id (match shot name or entity name)\nconst relatedTasks = allTasks.filter(t =>\n  (t.entity_name === content_id || t.name === content_id ||\n   t.entity_id === content_id) &&\n  (!data.steps || steps.includes(t.task_type_priority || t.priority))\n);\n\n// Fetch status IDs to map status name to ID\nconst statusesResp = await $http.request({\n  method: 'GET',\n  url: 'http://kitsu:80/api/data/task-status',\n  headers: { 'Authorization': `Bearer ${kitsu_token}` }\n});\n\nconst statuses = statusesResp.data || statusesResp || [];\nconst statusObj = statuses.find(s =>\n  s.name === kitsuStatus || s.short_name === kitsuStatus.toLowerCase()\n);\n\nconst task_status_id = statusObj ? statusObj.id : null;\nconst results = [];\n\nfor (const task of relatedTasks) {\n  try {\n    const resp = await $http.request({\n      method: 'POST',\n      url: `http://kitsu:80/api/actions/tasks/${task.id}/comment`,\n      headers: {\n        'Authorization': `Bearer ${kitsu_token}`,\n        'Content-Type': 'application/json'\n      },\n      body: {\n        task_status_id: task_status_id || task.task_status_id,\n        comment\n      }\n    });\n    results.push({ task_id: task.id, status: 'updated' });\n  } catch (err) {\n    results.push({ task_id: task.id, status: 'error', error: err.message });\n  }\n}\n\nreturn [{ json: { action: 'update_task_status', content_id, kitsu_status: kitsuStatus, tasks_updated: results.length, results } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000005",
      "name": "Update Task Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 180]
    },
    {
      "parameters": {
        "jsCode": "// Create a new shot in Kitsu for the content\n// Called when a new content_id is created in the pipeline\nconst { content_id, data, kitsu_token } = $input.first().json;\n\nconst project_id   = data.project_id   || '19b9faf4-f7c4-4829-9739-cbf7c3181941';\nconst episode_id   = data.episode_id   || null;\nconst sequence_id  = data.sequence_id  || null;\nconst shot_name    = data.shot_name    || content_id;\nconst description  = data.description || '';\n\nconst shot_payload = {\n  project_id,\n  name: shot_name,\n  description\n};\nif (episode_id)  shot_payload.episode_id  = episode_id;\nif (sequence_id) shot_payload.sequence_id = sequence_id;\n\nconst resp = await $http.request({\n  method: 'POST',\n  url: `http://kitsu:80/api/data/projects/${project_id}/shots`,\n  headers: {\n    'Authorization': `Bearer ${kitsu_token}`,\n    'Content-Type': 'application/json'\n  },\n  body: shot_payload\n});\n\nreturn [{ json: { action: 'create_shot', content_id, shot_id: resp.id || resp.shot_id, kitsu_response: resp } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000006",
      "name": "Create Shot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 360]
    },
    {
      "parameters": {
        "jsCode": "// Upload a preview file to Kitsu for a given task\nconst { content_id, data, kitsu_token } = $input.first().json;\n\nconst task_id     = data.task_id;\nconst preview_url = data.preview_url;\n\nif (!task_id)     throw new Error('Missing required field: data.task_id');\nif (!preview_url) throw new Error('Missing required field: data.preview_url');\n\n// Download asset from preview_url\nconst assetResp = await $http.request({\n  method: 'GET',\n  url: preview_url,\n  encoding: 'arraybuffer'\n});\n\n// Upload to Kitsu preview-files endpoint\nconst resp = await $http.request({\n  method: 'POST',\n  url: `http://kitsu:80/api/pictures/preview-files/${task_id}`,\n  headers: {\n    'Authorization': `Bearer ${kitsu_token}`,\n    'Content-Type': 'application/octet-stream'\n  },\n  body: assetResp\n});\n\nreturn [{ json: { action: 'upload_preview', content_id, task_id, preview_id: resp.id || resp.preview_id, kitsu_response: resp } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000007",
      "name": "Upload Preview",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 540]
    },
    {
      "parameters": {
        "jsCode": "// Add a comment to a Kitsu task\nconst { content_id, data, kitsu_token } = $input.first().json;\n\nconst task_id = data.task_id;\nconst comment = data.comment || '';\nconst task_status_id = data.task_status_id || null;\n\nif (!task_id) throw new Error('Missing required field: data.task_id');\n\nconst payload = { comment };\nif (task_status_id) payload.task_status_id = task_status_id;\n\nconst resp = await $http.request({\n  method: 'POST',\n  url: `http://kitsu:80/api/actions/tasks/${task_id}/comment`,\n  headers: {\n    'Authorization': `Bearer ${kitsu_token}`,\n    'Content-Type': 'application/json'\n  },\n  body: payload\n});\n\nreturn [{ json: { action: 'add_comment', content_id, task_id, comment_id: resp.id || resp.comment_id, kitsu_response: resp } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000008",
      "name": "Add Comment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 720]
