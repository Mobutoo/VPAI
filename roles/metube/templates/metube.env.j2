# {{ ansible_managed }}
# MeTube environment — video downloader (yt-dlp web UI)

DOWNLOAD_DIR=/downloads
OUTPUT_TEMPLATE={{ metube_output_template }}
{% if videoref_port | default('') | string | length > 0 %}
# yt-dlp Exec postprocessor: notify VideoRef Engine after each download
# Uses python3 (available in container) since wget/curl are not installed
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best","postprocessors":[{"key":"Exec","exec_cmd":"python3 -c \"import urllib.request,json,os;p=os.path.basename('%(filepath)s');urllib.request.urlopen(urllib.request.Request('http://workstation_videoref:{{ videoref_port }}/api/webhook/metube',json.dumps({'filename':p}).encode(),headers={'Content-Type':'application/json'}))\" || true"}]}
{% else %}
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best"}
{% endif %}
