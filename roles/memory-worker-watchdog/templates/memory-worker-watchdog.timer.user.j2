[Unit]
Description=Lance memory-worker-watchdog periodiquement (sonde stagnation, user)

[Timer]
OnBootSec={{ memory_worker_watchdog_timer_on_boot_sec }}
OnUnitActiveSec={{ memory_worker_watchdog_timer_on_unit_active_sec }}
Unit={{ memory_worker_watchdog_service_name }}.service
Persistent=true

[Install]
WantedBy=timers.target
