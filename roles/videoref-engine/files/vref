def cmd_cameras(args: argparse.Namespace) -> None:
    """List available camera presets."""
    data = _api("GET", "/api/cameras")
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    cameras = data.get("cameras", {})
    lenses = data.get("lenses", {})
    apertures = data.get("apertures", {})
    motions = data.get("motions", {})

    print("Camera Presets\n")
    if cameras:
        print("  Cameras:")
        for name, desc in cameras.items():
            label = desc if isinstance(desc, str) else json.dumps(desc)
            print(f"    {name:20s}  {label[:50]}")
    if lenses:
        print("\n  Lenses:")
        for name, desc in lenses.items():
            label = desc if isinstance(desc, str) else json.dumps(desc)
            print(f"    {name:20s}  {label[:50]}")
    if apertures:
        print("\n  Apertures:")
        for name, desc in apertures.items():
            label = desc if isinstance(desc, str) else json.dumps(desc)
            print(f"    {name:20s}  {label[:50]}")
    if motions:
        print("\n  Motions:")
        for name, desc in motions.items():
            label = desc if isinstance(desc, str) else json.dumps(desc)
            print(f"    {name:20s}  {label[:50]}")
    if not any([cameras, lenses, apertures, motions]):
        print("  No presets loaded (camera-presets.json not found in Gitea)")


def cmd_produce_start(args: argparse.Namespace) -> None:
    """Start a new production job."""
    title = args.title
    if not title:
        print("Error: --title is required")
        sys.exit(1)

    body = {"title": title}
    if args.url:
        body["url"] = args.url
    if args.camera:
        body["camera"] = args.camera
    if args.lens:
        body["lens"] = args.lens
    if args.aperture:
        body["aperture"] = args.aperture
    if args.cam_motion:
        body["motion"] = args.cam_motion
    if args.fps:
        body["fps"] = args.fps
    if args.format:
        body["format"] = args.format
    if args.style:
        body["style"] = args.style

    data = _api("POST", "/api/produce/start", body)
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    slug = data.get("slug", "")
    print(f"Production job created!")
    print(f"  Slug:    {slug}")
    print(f"  Job ID:  {data.get('job_id', '?')}")
    print(f"  Title:   {data.get('title', '?')}")
    print(f"  Next:    {data.get('next_step', '?')}")
    print(f"\n  Pipeline: {' -> '.join(data.get('pipeline_steps', []))}")
    print(f"\n  Run: vref produce-step {slug or data.get('job_id', 'JOB_ID')} brief")


def cmd_produce_step(args: argparse.Namespace) -> None:
    """Execute a pipeline step."""
    job_id = args.job_id
    step = args.step

    if step not in PIPELINE_STEPS:
        print(f"Error: Unknown step '{step}'. Valid: {', '.join(PIPELINE_STEPS)}")
        sys.exit(1)

    params = {}
    if args.description:
        params["description"] = args.description
    if args.query_param:
        params["query"] = args.query_param
    if args.url:
        params["url"] = args.url
    if args.skip:
        params["skip"] = True
    if args.scenes:
        params["scenes"] = _parse_scene_list(args.scenes)
    if args.modifications:
        params["modifications"] = _parse_modifications(args.modifications)
    if hasattr(args, "fps") and args.fps:
        params["fps"] = args.fps
    if hasattr(args, "format") and args.format:
        params["format"] = args.format
    if hasattr(args, "resolution") and args.resolution:
        params["resolution"] = args.resolution

    print(f"Executing step '{step}' for job {job_id[:8]}...")
    data = _api("POST", "/api/produce/step", {
        "job_id": job_id,
        "step": step,
        "params": params,
    })
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    print(f"Step '{step}' completed!")
    completed = data.get("steps_completed", [])
    next_step = data.get("next_step", "done")
    print(f"  Completed: {', '.join(completed)}")
    print(f"  Next:      {next_step or 'DONE'}")
    result = data.get("step_result", {})
    kitsu = result.get("kitsu", {})
    if kitsu.get("task_id"):
        print(f"  Kitsu:     task {kitsu['task_id'][:8]}... -> {kitsu.get('status', '?')}")
    if next_step:
        print(f"\n  Run: vref produce-step {job_id} {next_step}")


def cmd_produce_status(args: argparse.Namespace) -> None:
    """Show production job status."""
    job_id = args.job_id
    data = _api("GET", f"/api/produce/status/{job_id}")
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return

    progress = data.get("progress", 0)
    bar_len = 30
    filled = int(progress * bar_len)
    bar = "#" * filled + "." * (bar_len - filled)
    pct = int(progress * 100)

    slug = data.get("slug", "")
    print(f"Production: {data.get('title', '?')}")
    if slug:
        print(f"  Slug:     {slug}")
    print(f"  Job ID:   {data.get('job_id', '?')}")
    if data.get("camera"):
        print(f"  Camera:   {data.get('camera', '')} | Lens: {data.get('lens', '')}")
    print(f"  Progress: [{bar}] {pct}%")
    print(f"  Current:  {data.get('current_step') or 'DONE'}")
    if data.get("kitsu_sequence_id"):
        print(f"  Kitsu:    sequence {data['kitsu_sequence_id'][:8]}...")
    print(f"  Created:  {data.get('created_at', '?')[:19]}")
    print(f"  Updated:  {data.get('updated_at', '?')[:19]}")

    print(f"\n  Steps:")
    for s in data.get("steps", []):
        status = "[x]" if s["completed"] else "[ ]"
        human = " (human)" if s["needs_human"] else ""
        optional = " (optional)" if s["optional"] else ""
        print(f"    {status} {s['id']:15s} {s['task_type']}{human}{optional}")


def cmd_produce_retake(args: argparse.Namespace) -> None:
    """Retake a specific pipeline step."""
    job_id = args.job_id
    step = args.step

    if step not in PIPELINE_STEPS:
        print(f"Error: Unknown step '{step}'. Valid: {', '.join(PIPELINE_STEPS)}")
        sys.exit(1)

    body: dict = {
        "job_id": job_id,
        "step": step,
    }
    if args.scenes:
        body["scenes"] = _parse_scene_list(args.scenes)
    if args.modifications:
        body["modifications"] = _parse_modifications(args.modifications)

    print(f"Retaking step '{step}' for job {job_id[:8]}...")
    data = _api("POST", "/api/produce/retake", body)
    if args.json:
        _print_json(data)
        return
    if "error" in data:
        print(f"Error: {data['error']}")
        return
    print(f"Retake of '{step}' completed!")
    if data.get("scenes_retaken"):
        print(f"  Scenes retaken: {data['scenes_retaken']}")


# -- Helpers -------------------------------------------------------

def _parse_scene_list(scenes_str: str) -> list[int]:
    """Parse comma-separated scene indices string to list of ints."""
    result = []
    for part in scenes_str.split(","):
        part = part.strip()
        if part.isdigit():
            result.append(int(part))
    return result


def _parse_modifications(mods_str: str) -> dict:
    """Parse key=value modifications string to dict."""
    result = {}
    for part in mods_str.split(","):
        if "=" in part:
            k, v = part.split("=", 1)
            result[k.strip()] = v.strip()
    return result


# -- Parser --------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="vref",
        description="VideoRef Engine CLI -- creative video reference pipeline v0.7.0",
        epilog="Environment: VREF_URL (default: https://cine.ewutelo.cloud)",
    )
    parser.add_argument("--json", action="store_true", help="Output raw JSON")
    sub = parser.add_subparsers(dest="command", help="Command")

    # health
    sub.add_parser("health", help="Check service health")

    # watch
    sub.add_parser("watch", help="List downloaded videos")

    # jobs
    sub.add_parser("jobs", help="List completed analyses")

    # analyze
    p = sub.add_parser("analyze", help="Analyze a video file")
    p.add_argument("filename", help="Video filename in watch dir")
    p.add_argument("--template", default="default", help="ComfyUI template (default/cinematic/anime)")

    # assets
    p = sub.add_parser("assets", help="Search VideoRef assets in Kitsu")
    p.add_argument("--style", help="Filter by style")
    p.add_argument("--mood", help="Filter by mood")
    p.add_argument("--motion", help="Filter by motion (low/medium/high)")
    p.add_argument("-q", "--query", help="Free text search")
    p.add_argument("--limit", type=int, default=20, help="Max results")

    # get
    p = sub.add_parser("get", help="Get full asset details")
    p.add_argument("asset_id", help="Kitsu asset UUID")

    # prompt
    p = sub.add_parser("prompt", help="Print AI prompt (for piping)")
    p.add_argument("asset_id", help="Kitsu asset UUID")

    # search
    p = sub.add_parser("search", help="Semantic search via Qdrant")
    p.add_argument("query", nargs="+", help="Search query")
    p.add_argument("--limit", type=int, default=5, help="Max results")

    # remix (updated with camera params)
    p = sub.add_parser("remix", help="Remix an asset with modifications")
    p.add_argument("asset_id", nargs="?", help="Kitsu asset UUID (or use --source-prompt)")
    p.add_argument("--source-prompt", help="Direct prompt instead of asset_id")
    p.add_argument("--subject", help="Change subject (e.g. 'cats instead of shoes')")
    p.add_argument("--style", help="Change style (e.g. 'watercolor painting')")
    p.add_argument("--mood", help="Change mood (e.g. 'melancholic')")
    p.add_argument("--colors", help="Override colors (e.g. '#1a1a2e, #16213e')")
    p.add_argument("--extra", help="Additional modifications")
    p.add_argument("--camera", help="Camera preset (e.g. ARRI, RED, Sony)")
    p.add_argument("--lens", help="Lens type (e.g. anamorphic, prime, zoom)")
    p.add_argument("--aperture", help="Aperture value (e.g. 1.4, 2.8)")
    p.add_argument("--cam-motion", help="Camera motion (e.g. dolly, pan, steadicam)")
    p.add_argument("--template", default="cinematic", help="ComfyUI template")
    p.add_argument("--output", help="Output workflow name")

    # cameras
    sub.add_parser("cameras", help="List available camera presets")

    # produce-start
    p = sub.add_parser("produce-start", help="Start a new production job")
    p.add_argument("--title", required=True, help="Production title")
    p.add_argument("--url", help="Source video URL")
    p.add_argument("--camera", help="Camera preset")
    p.add_argument("--lens", help="Lens type")
    p.add_argument("--aperture", help="Aperture value")
    p.add_argument("--cam-motion", help="Camera motion")
    p.add_argument("--fps", default="24", help="Frame rate (default: 24)")
    p.add_argument("--format", default="landscape",
                   choices=["landscape", "portrait", "square", "4k", "4k-portrait", "cinescope"],
                   help="Video format/orientation (default: landscape)")
    p.add_argument("--style", default="2d3d",
                   choices=["2d", "3d", "2d3d", "ar", "vfx"],
                   help="Production style (default: 2d3d)")

    # produce-step
    p = sub.add_parser("produce-step", help="Execute a pipeline step")
    p.add_argument("job_id", help="Production job ID")
    p.add_argument("step", help=f"Step name: {', '.join(PIPELINE_STEPS)}")
    p.add_argument("--description", help="Brief description (for brief step)")
    p.add_argument("--fps", help="Override FPS (for brief step)")
    p.add_argument("--format", help="Override format: landscape/portrait/square/4k (for brief)")
    p.add_argument("--resolution", help="Override resolution e.g. 1920x1080 (for brief)")
    p.add_argument("--query-param", help="Search query (for research step)")
    p.add_argument("--url", help="Source URL (for research step)")
    p.add_argument("--skip", action="store_true", help="Skip optional step")
    p.add_argument("--scenes", help="Comma-separated scene indices")
    p.add_argument("--modifications", help="key=value,key=value modifications")

    # produce-status
    p = sub.add_parser("produce-status", help="Show production job status")
    p.add_argument("job_id", help="Production job ID")

    # produce-retake
    p = sub.add_parser("produce-retake", help="Retake a specific pipeline step")
    p.add_argument("job_id", help="Production job ID")
    p.add_argument("step", help=f"Step to retake: {', '.join(PIPELINE_STEPS)}")
    p.add_argument("--scenes", help="Comma-separated scene indices to retake")
    p.add_argument("--modifications", help="key=value,key=value modifications")

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    commands = {
        "health": cmd_health,
        "watch": cmd_watch,
        "jobs": cmd_jobs,
        "analyze": cmd_analyze,
        "assets": cmd_assets,
        "get": cmd_get,
        "prompt": cmd_prompt,
        "search": cmd_search,
        "remix": cmd_remix,
        "cameras": cmd_cameras,
        "produce-start": cmd_produce_start,
        "produce-step": cmd_produce_step,
        "produce-status": cmd_produce_status,
        "produce-retake": cmd_produce_retake,
    }

    fn = commands.get(args.command)
    if fn:
        fn(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
