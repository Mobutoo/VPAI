# {{ ansible_managed }}
# Postiz (Content Factory V-0) — env applicatif.
# Référence : docs.postiz.com/configuration/reference + compose officiel
# github.com/gitroomhq/postiz-docker-compose (source canonique, lu 2026-07-10).

# === Requis
MAIN_URL=https://{{ caddy_postiz_domain }}
FRONTEND_URL=https://{{ caddy_postiz_domain }}
NEXT_PUBLIC_BACKEND_URL=https://{{ caddy_postiz_domain }}/api
JWT_SECRET={{ vault_postiz_jwt_secret }}
DATABASE_URL=postgresql://{{ postiz_pg_user }}:{{ postgresql_password }}@{{ postiz_pg_container }}:5432/{{ postiz_db_name }}
REDIS_URL=redis://{{ postiz_redis_container }}:6379
BACKEND_INTERNAL_URL=http://localhost:3000

# === Temporal (>= 2.12 : posts planifiés + workflows) — cf-temporal mutualisé
TEMPORAL_ADDRESS={{ postiz_temporal_address }}
TEMPORAL_NAMESPACE={{ postiz_temporal_namespace }}

# === Comportement
IS_GENERAL=true
DISABLE_REGISTRATION={{ postiz_disable_registration | lower }}
RUN_CRON=true

# === Stockage local (volume dédié)
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# === Divers (défauts compose officiel)
NX_ADD_PLUGINS=false
API_LIMIT=30

# === Comptes sociaux (GATE HUMAIN — clés API par plateforme, à remplir plus tard
#     via vault si publication API requise ; l'UI gère aussi l'OAuth par compte)
