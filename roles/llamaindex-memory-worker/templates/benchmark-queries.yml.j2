queries:
  - repo: VPAI
    query: "Where is the main production deployment playbook defined?"
    accepted_paths:
      - playbooks/site.yml
  - repo: VPAI
    query: "Where is the workstation deployment playbook defined?"
    accepted_paths:
      - playbooks/workstation.yml
  - repo: VPAI
    query: "Where are the inventory hosts for this infrastructure defined?"
    accepted_paths:
      - inventory/hosts.yml
  - repo: VPAI
    query: "Where is the memory worker role configured?"
    accepted_paths:
      - roles/llamaindex-memory-worker/defaults/main.yml
      - roles/llamaindex-memory-worker/tasks/main.yml
  - repo: VPAI
    query: "Where is the n8n workflow that ingests memory run reports?"
    accepted_paths:
      - scripts/n8n-workflows/memory-run-report-ingest.json
  - repo: VPAI
    query: "Where is the n8n memory healthcheck workflow defined?"
    accepted_paths:
      - scripts/n8n-workflows/memory-healthcheck.json
  - repo: VPAI
    query: "Where are the memory worker operations documented?"
    accepted_paths:
      - docs/runbooks/AI-MEMORY-OPERATIONS.md
  - repo: VPAI
    query: "Where are deployment shortcuts and developer commands defined?"
    accepted_paths:
      - Makefile
  - repo: flash-studio
    query: "Where is the flash-infra architecture documented?"
    accepted_paths:
      - flash-infra/ARCHITECTURE.md
  - repo: flash-studio
    query: "Where is the main flash infrastructure deployment playbook?"
    accepted_paths:
      - flash-infra/ansible/playbooks/site.yml
  - repo: flash-studio
    query: "Where is the quick reference for the daemon workflow documented?"
    accepted_paths:
      - docs/QUICK_REFERENCE.md
  - repo: flash-studio
    query: "Where is the initialization guide for Flash Studio documented?"
    accepted_paths:
      - docs/GUIDE_INITIALISATION.md
  - repo: flash-studio
    query: "Where is the daemon launcher script implemented?"
    accepted_paths:
      - flash-infra/scripts/flash-daemon.sh
  - repo: flash-studio
    query: "Where is the CLI script to control Flash Studio daemons?"
    accepted_paths:
      - flash-infra/scripts/flash-ctl.sh
  - repo: flash-studio
    query: "Where is the playbook to rebuild a work VM after destruction?"
    accepted_paths:
      - flash-infra/ansible/playbooks/rebuild-work.yml
  - repo: flash-studio
    query: "Where is the zero-trust infrastructure overview documented?"
    accepted_paths:
      - flash-infra/README.md
      - flash-infra/ARCHITECTURE.md
  - repo: story-engine
    query: "Where is the collaboration websocket server implemented?"
    accepted_paths:
      - apps/collab/src/server.ts
  - repo: story-engine
    query: "Where is the collaboration healthcheck implemented?"
    accepted_paths:
      - apps/collab/src/health.ts
  - repo: story-engine
    query: "Where is the FastAPI entrypoint for StoryEngine implemented?"
    accepted_paths:
      - apps/api/src/story_engine/main.py
  - repo: story-engine
    query: "Where is the monorepo architecture and stack described?"
    accepted_paths:
      - CLAUDE.md
  - repo: story-engine
    query: "Where is the gaps resolution specification documented?"
    accepted_paths:
      - docs/specs/2026-04-01-gaps-resolution.md
  - repo: story-engine
    query: "Where is the editor extension registry implemented?"
    accepted_paths:
      - packages/editor/src/extensions.ts
  - repo: story-engine
    query: "Where is the development docker stack for StoryEngine defined?"
    accepted_paths:
      - infra/docker-compose.yml
  - repo: story-engine
    query: "Where is the collaboration database extension implemented?"
    accepted_paths:
      - apps/collab/src/extensions/database.ts
