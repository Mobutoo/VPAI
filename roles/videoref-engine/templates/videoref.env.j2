# {{ ansible_managed }}
# VideoRef Engine environment — video analysis + ComfyUI workflow generation

WATCH_DIR=/watch
OUTPUT_DIR=/analyzed
COMFYUI_WORKFLOWS_DIR=/comfyui-workflows
LITELLM_URL={{ videoref_litellm_url }}
LITELLM_API_KEY={{ videoref_litellm_key }}
{% if videoref_gitea_url | default('') | length > 0 %}
GITEA_URL={{ videoref_gitea_url }}
GITEA_TOKEN={{ videoref_gitea_token }}
{% endif %}
{% if videoref_kitsu_url | default('') | length > 0 %}
KITSU_URL={{ videoref_kitsu_url }}
KITSU_TOKEN={{ videoref_kitsu_token }}
KITSU_ADMIN_EMAIL={{ kitsu_admin_email | default('admin@admin.com') }}
KITSU_ADMIN_PASSWORD={{ kitsu_admin_password | default('mysecretpassword') }}
{% endif %}
{% if videoref_qdrant_url | default('') | length > 0 %}
QDRANT_URL={{ videoref_qdrant_url }}
QDRANT_API_KEY={{ videoref_qdrant_key }}
QDRANT_COLLECTION={{ videoref_qdrant_collection }}
{% endif %}
# ComfyUI API (local, same Docker network)
COMFYUI_API_URL=http://workstation_comfyui:8188
# Remotion render server (montage, transitions, titles, subtitles)
REMOTION_URL=http://workstation_remotion:3200
# fal.ai direct API (video nodes bypass ComfyUI — video nodes return STRING not IMAGE)
FAL_API_KEY={{ fal_ai_api_key }}
# BytePlus Seedance direct API (bypass fal.ai — ~60% cheaper for same model)
{% if byteplus_api_key | default('') | length > 0 %}
BYTEPLUS_API_KEY={{ byteplus_api_key }}
{% endif %}
# n8n creative pipeline (image gen + video gen orchestration)
N8N_CREATIVE_PIPELINE_URL=https://{{ n8n_subdomain }}.{{ domain_name }}/webhook/creative-pipeline
# Telegram notifications — OpenClaw bot, Studio topic (173)
TELEGRAM_BOT_TOKEN={{ telegram_openclaw_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_openclaw_group_id }}
TELEGRAM_TOPIC_ID={{ telegram_openclaw_topic_ids.studio | default('173') }}
# Google Gemini direct API (fallback when LiteLLM budget exceeded)
{% if google_gemini_api_key | default('') | length > 0 %}
GOOGLE_API_KEY={{ google_gemini_api_key }}
{% endif %}
# Claude Code CLI bridge (Max OAuth, Opus 4.6 — scene decomposition on Waza)
CLAUDE_CLI_PATH={{ claude_cli_path | default('/usr/local/bin/claude') }}
