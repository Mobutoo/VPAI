              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.metube_payload) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "vri-0001-0000-4000-8000-000000000003",
      "name": "POST metube /add",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_MONITORING_BOT_TOKEN }}/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "={{ $env.TELEGRAM_MONITORING_CHAT_ID }}"
            },
            {
              "name": "parse_mode",
              "value": "HTML"
            },
            {
              "name": "text",
              "value": "=\ud83d\udce5 <b>VRef Remix</b> \u2014 T\u00e9l\u00e9chargement lanc\u00e9\n\n\ud83c\udfac <b>{{ $('Validate & Prepare').first().json.title }}</b>\n\n\ud83c\udf10 <code>{{ $('Validate & Prepare').first().json.source_url.slice(0,60) }}</code>\n\n\u23f3 T\u00e9l\u00e9chargement vid\u00e9o en cours (1-3 min)..."
            }
          ]
        },
        "options": {}
      },
      "id": "vri-0001-0000-4000-8000-000000000014",
      "name": "TG: Downloading",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        920,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Validate & Prepare').first().json;\nconst metube_url = ctx.metube_url;\nconst source_url = ctx.source_url;\n\nconst timeout = 300000;\nconst interval = 5000;\nconst start = Date.now();\n\nlet result = null;\nwhile (!result && (Date.now() - start) < timeout) {\n  await new Promise(r => setTimeout(r, interval));\n  let history;\n  try {\n    const raw = await $http.request({ method: 'GET', url: metube_url + '/history' });\n    history = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  } catch(e) {\n    continue;\n  }\n  const allItems = [\n    ...(Array.isArray(history.done)    ? history.done    : Object.values(history.done    || {})),\n    ...(Array.isArray(history.queue)   ? history.queue   : Object.values(history.queue   || {})),\n    ...(Array.isArray(history.pending) ? history.pending : Object.values(history.pending || {})),\n  ];\n  const match = allItems.find(item =>\n    item.url === source_url &&\n    (item.status === 'finished' || item.status === 'done')\n  );\n  if (match) {\n    result = {\n      filename: match.title + '.' + (match.format || 'mp4'),\n      video_title: match.title,\n      video_id: match.id,\n    };\n  }\n}\n\nif (!result) throw new Error('Metube download timeout after 5 min: ' + source_url);\n\nreturn [{ json: { ...ctx, ...result } }];"
      },
