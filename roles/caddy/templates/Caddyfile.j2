# === Flash Suite (unified dashboard) — suite.<domain> ===
# Architecture: Shell (Next.js) = dashboard + auth. Sub-apps served directly at their paths.
# Ase (Django/Vite) assets are at /assets/ (no /flow/ prefix — Vite base path not set at build time).
{% if flash_suite_subdomain | default('') | length > 0 %}
{{ flash_suite_subdomain }}.{{ domain_name }} {
    import vpn_only
    import vpn_error_page

    # --- Ase (Flow Engine — Django + Vite SPA) ---
    # WebSocket for Django Channels
    @ase_ws {
        path /flow/ws/*
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @ase_ws {
        reverse_proxy suite_ase:8000
    }

    # Vite assets (build output at /assets/, not /flow/assets/)
    handle /assets/* {
        reverse_proxy suite_ase:8000
    }
    handle /vite.svg {
        reverse_proxy suite_ase:8000
    }

    # Flow pages + API
    handle /flow* {
        reverse_proxy suite_ase:8000
    }

    # --- Koodia (Food — API only, Shell renders the UI) ---
    @koodia_sse {
        path /food/api/*/stream
    }
    handle @koodia_sse {
        reverse_proxy suite_koodia:3100 {
            flush_interval -1
        }
    }
    handle /food/api/* {
        reverse_proxy suite_koodia:3100
    }

    # --- Zimboo (Finance — Next.js with basePath=/finance) ---
    handle /finance* {
        reverse_proxy suite_zimboo:3000
    }

    # Zimboo API workaround — client-side code calls /api/* without /finance prefix
    # Rewrite to /finance/api/* so Zimboo serves them correctly.
    # Exclude Shell's own API routes (/api/auth, /api/events, /api/health, /api/suite).
    @zimboo_api {
        path /api/*
        not path /api/suite/*
        not path /api/auth/*
        not path /api/events/*
        not path /api/health/*
    }
    handle @zimboo_api {
        rewrite * /finance{uri}
        reverse_proxy suite_zimboo:3000
    }

    # --- Shell (dashboard, auth, catch-all) ---
    handle {
        reverse_proxy suite_shell:{{ flash_suite_shell_port | default(3500) }}
    }

    import security_headers
}
{% endif %}

