# === n8n - dedicated subdomain ===
# REX: n8n does NOT support sub-path deployment (GitHub issue #19635)
{% if n8n_subdomain | default('') | length > 0 %}
{{ caddy_n8n_domain }} {
    # Public Telegram webhook — secret_token header validated inside n8n workflow.
    # Must be BEFORE vpn_only to let Telegram servers reach the bot from the internet.
    handle /webhook/memory-telegram-bot {
        reverse_proxy n8n:5678
    }

    import vpn_only
    import vpn_error_page

    # R11: explicit route for n8n public REST API (PUT /api/v1/workflows/:id)
    handle /api/v1/* {
        reverse_proxy n8n:5678
    }

    # MOP: static PDF files generated by mop-generate workflow
    # VPN ACL inherited from `import vpn_only` above — no extra restriction needed
    handle /files/* {
        root * /srv/mop-pdf
        file_server
    }

    reverse_proxy n8n:5678

    import security_headers
}
{% endif %}

# === LiteLLM - dedicated subdomain ===
# REX: LiteLLM UI does NOT support sub-path (SERVER_ROOT_PATH buggy: issues #11451, #11865)
# REX: App servers (Hetzner) need API access — caddy_trusted_app_ips added alongside VPN CIDRs
{% if litellm_subdomain | default('') | length > 0 %}
{{ caddy_litellm_domain }} {
{% if caddy_trusted_app_ips | default([]) | length > 0 %}
    # Server-to-server API access (VPN + trusted app servers)
    @blocked_llm not client_ip {{ caddy_vpn_cidr }} {{ caddy_docker_frontend_cidr }} {{ caddy_trusted_app_ips | join(' ') }}
    error @blocked_llm 403
{% else %}
    import vpn_only
{% endif %}
    import vpn_error_page

    reverse_proxy litellm:4000

    import security_headers
}
{% endif %}

