#!/usr/bin/env python3
"""Zou event handler — forwards events to n8n Content Factory webhook.

Loaded by Zou from EVENT_HANDLERS_FOLDER. Called for every Zou event.
Uses internal Docker networking (n8n container name) to avoid VPN/Caddy layer.
"""
import json
import urllib.request

N8N_WEBHOOK_URL = "http://{{ project_name }}_n8n:5678/webhook/cf-kitsu-inbound"
WEBHOOK_SECRET = "{{ n8n_webhook_secret }}"


def handle_event(data):
    """Called by Zou for every event. Best-effort — do not crash Zou."""
    event_type = data.get("type", "unknown")

    # Only forward relevant Content Factory events
    RELEVANT_EVENTS = {
        "task:status-changed",
        "preview-file:new",
        "comment:new",
    }

    if event_type not in RELEVANT_EVENTS:
        return

    payload = json.dumps({
        "secret": WEBHOOK_SECRET,
        "event_type": event_type,
        "data": data
    }).encode("utf-8")

    req = urllib.request.Request(
        N8N_WEBHOOK_URL,
        data=payload,
        headers={"Content-Type": "application/json"}
    )

    try:
        urllib.request.urlopen(req, timeout=10)
    except Exception:
        pass  # Best-effort — don't crash Zou if n8n is down
