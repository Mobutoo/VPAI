---
# docker-compose-penpot.yml — Penpot stack (ephemeral VPS)
# Generated by Ansible — do not edit manually

services:
  penpot-frontend:
    image: "{{ penpot_image_frontend }}"
    container_name: penpot_frontend
    restart: unless-stopped
    ports:
      - "{{ penpot_frontend_port }}:8080"
    volumes:
      - penpot_assets:/opt/data/assets
    depends_on:
      penpot-backend:
        condition: service_started
      penpot-exporter:
        condition: service_started
    environment:
      PENPOT_FLAGS: "disable-registration enable-login-with-password"
    deploy:
      resources:
        limits:
          memory: 512M

  penpot-backend:
    image: "{{ penpot_image_backend }}"
    container_name: penpot_backend
    restart: unless-stopped
    volumes:
      - penpot_assets:/opt/data/assets
    depends_on:
      penpot-postgres:
        condition: service_healthy
      penpot-valkey:
        condition: service_started
    environment:
      PENPOT_FLAGS: "disable-registration enable-login-with-password disable-email-verification enable-backend-prepl"
      PENPOT_SECRET_KEY: "{{ penpot_secret_key }}"
      PENPOT_PUBLIC_URI: "https://{{ penpot_domain }}"
      PENPOT_DATABASE_URI: "postgresql://penpot-postgres/{{ penpot_db_name }}"
      PENPOT_DATABASE_USERNAME: "{{ penpot_db_user }}"
      PENPOT_DATABASE_PASSWORD: "{{ penpot_db_password }}"
      PENPOT_REDIS_URI: "redis://penpot-valkey/0"
      PENPOT_ASSETS_STORAGE_BACKEND: "assets-fs"
      PENPOT_STORAGE_ASSETS_FS_DIRECTORY: "/opt/data/assets"
      PENPOT_TELEMETRY_ENABLED: "false"
      PENPOT_SECURE_SESSION_COOKIES: "true"
      PENPOT_PREPL_HOST: "0.0.0.0"
    deploy:
      resources:
        limits:
          memory: 1536M

  penpot-exporter:
    image: "{{ penpot_image_exporter }}"
    container_name: penpot_exporter
    restart: unless-stopped
    environment:
      PENPOT_PUBLIC_URI: "http://penpot-frontend:8080"
      PENPOT_REDIS_URI: "redis://penpot-valkey/0"
    deploy:
      resources:
        limits:
          memory: 512M

  penpot-postgres:
    image: "{{ penpot_image_pg }}"
    container_name: penpot_postgres
    restart: unless-stopped
    volumes:
      - penpot_pgdata:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: "{{ penpot_db_name }}"
      POSTGRES_USER: "{{ penpot_db_user }}"
      POSTGRES_PASSWORD: "{{ penpot_db_password }}"
      POSTGRES_INITDB_ARGS: "--data-checksums"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ penpot_db_user }} -d {{ penpot_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    deploy:
      resources:
        limits:
          memory: 768M

  penpot-valkey:
    image: "{{ penpot_image_valkey }}"
    container_name: penpot_valkey
    restart: unless-stopped
    command: "valkey-server --maxmemory 128mb --maxmemory-policy volatile-lfu"
    volumes:
      - penpot_valkey:/data
    deploy:
      resources:
        limits:
          memory: 256M

volumes:
  penpot_assets:
    driver: local
  penpot_pgdata:
    driver: local
  penpot_valkey:
    driver: local
