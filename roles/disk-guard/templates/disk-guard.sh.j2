#!/bin/bash
# {{ ansible_managed }}
# disk-guard — purge le disque sous pression (paliers SOFT→HARD).
# Idempotent : no-op tant que l'usage < SOFT. Lock flock anti-concurrence.
set -euo pipefail

SOFT={{ disk_guard_threshold_soft }}
MID={{ disk_guard_threshold_mid }}
HARD={{ disk_guard_threshold_hard }}
MOUNT="{{ disk_guard_mountpoint }}"
LEASE_MIN_AGE_DAYS={{ disk_guard_lease_min_age_days }}
IMAGE_MAX_AGE_HOURS={{ disk_guard_image_max_age_hours }}
ENV_FILE="{{ disk_guard_env_file }}"

# Secrets Telegram (fichier 0600). Absents = pas de notif.
TG_BOT=""
TG_CHAT=""
# shellcheck disable=SC1090
[ -r "$ENV_FILE" ] && . "$ENV_FILE"

log() { echo "[disk-guard] $*"; }

usage_pct() {
  df --output=pcent "$MOUNT" | tail -1 | tr -dc '0-9'
}

notify() {
  local msg="$1"
  [ -n "$TG_BOT" ] && [ -n "$TG_CHAT" ] || return 0
  curl -fsS --max-time 15 \
    "https://api.telegram.org/bot${TG_BOT}/sendMessage" \
    -d chat_id="${TG_CHAT}" \
    -d parse_mode="HTML" \
    --data-urlencode text="$msg" >/dev/null 2>&1 || log "notify telegram echec (non bloquant)"
}

# --- Anti-concurrence ---
exec 9>/run/disk-guard.lock
if ! flock -n 9; then
  log "run deja en cours, abandon"
  exit 0
fi

BEFORE="$(usage_pct)"
if [ "$BEFORE" -lt "$SOFT" ]; then
  log "usage ${BEFORE}% < ${SOFT}% — rien a faire"
  exit 0
fi

HOST="$(hostname -s)"
log "PRESSION disque ${BEFORE}% >= ${SOFT}% — purge SURE"

# ---------- PALIER 1 : SUR (zero re-pull) ----------
# 1a. Cache de build buildkit
docker builder prune -af >/dev/null 2>&1 || log "builder prune skip"
# 1b. Images dangling uniquement (pas -a)
docker image prune --force >/dev/null 2>&1 || log "image prune skip"

# 1c. Leases containerd orphelines > N jours — UNIQUEMENT si driver overlay2
#     (le store image-store containerd n'est alors pas l'actif → leases = reliquats).
DRIVER="$(docker info --format '{{ '{{' }}.Driver{{ '}}' }}' 2>/dev/null || echo unknown)"
if [ "$DRIVER" = "overlay2" ] && command -v ctr >/dev/null 2>&1; then
  CUTOFF="$(date -d "-${LEASE_MIN_AGE_DAYS} days" +%s)"
  N_DEL=0
  # Format ligne: <ID> <CREATED_AT RFC3339> <LABELS>
  while read -r LID LCREATED _; do
    [ -n "$LID" ] || continue
    LTS="$(date -d "$LCREATED" +%s 2>/dev/null || echo 0)"
    if [ "$LTS" -gt 0 ] && [ "$LTS" -lt "$CUTOFF" ]; then
      if ctr -n moby leases delete --sync "$LID" >/dev/null 2>&1; then
        N_DEL=$((N_DEL+1))
      fi
    fi
  done < <(ctr -n moby leases list 2>/dev/null | tail -n +2)
  [ "$N_DEL" -gt 0 ] && log "leases containerd orphelines supprimees: ${N_DEL}"
else
  log "driver=${DRIVER} — skip nettoyage leases containerd"
fi

AFTER_SOFT="$(usage_pct)"
log "apres palier SUR: ${AFTER_SOFT}%"

# ---------- PALIER 2 : MID (si toujours >= MID) ----------
# Filtre "until=" sur la date de CREATION (build) de l'image, pas sa derniere
# utilisation. Les images encore referencees par un conteneur existant restent
# epargnees (comportement -a standard, deploiement en cours protege) ; les
# images pinnees dans versions.yml restent re-pullables.
TIER_MID=""
if [ "$AFTER_SOFT" -ge "$MID" ]; then
  log "toujours ${AFTER_SOFT}% >= ${MID}% — purge MID (image prune -a, filtre until=${IMAGE_MAX_AGE_HOURS}h)"
  docker image prune -a --force --filter "until=${IMAGE_MAX_AGE_HOURS}h" >/dev/null 2>&1 || log "image prune -a (filtre age) skip"
  TIER_MID=" + image prune -a (>${IMAGE_MAX_AGE_HOURS}h)"
fi

AFTER_MID="$(usage_pct)"
log "apres palier MID: ${AFTER_MID}%"

# ---------- PALIER 3 : AGRESSIF (si toujours >= HARD) ----------
TIER_HARD=""
if [ "$AFTER_MID" -ge "$HARD" ]; then
  log "toujours ${AFTER_MID}% >= ${HARD}% — purge AGRESSIVE (image prune -a sans filtre)"
  docker image prune -a --force >/dev/null 2>&1 || log "image prune -a skip"
  TIER_HARD=" + image prune -a (sans filtre)"
fi

AFTER="$(usage_pct)"
log "FINAL: ${BEFORE}% -> ${AFTER}%"

# Notif uniquement si une action a eu lieu (on est >= SOFT par construction)
notify "🧹 <b>disk-guard</b> @ ${HOST}
Disque ${MOUNT} : <b>${BEFORE}% → ${AFTER}%</b>
Palier SUR (cache+dangling+leases)${TIER_MID}${TIER_HARD}"
