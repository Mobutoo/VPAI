# {{ ansible_managed }}
# Content Factory v2 (M0) — variante Sese-AI (FRUGAL).
# RÉUTILISE l'infra prod : Postgres `javisi_postgresql` (PG18.4) + réseaux externes
# `javisi_backend`/`javisi_frontend`. Routing via `javisi_caddy` (vhost hors de ce compose).
# 3 services : Temporal (auto-setup), API (FastAPI), Conductor (worker Temporal).

services:
  cf-temporal:
    image: {{ cf_temporal_image }}
    container_name: cf-temporal
    restart: unless-stopped
    environment:
      # auto-setup crée temporal + temporal_visibility + le namespace, DANS javisi_postgresql.
      DB: postgres12                       # nom du plugin driver (valide PG12..18), pas une version
      DB_PORT: "5432"                       # OBLIGATOIRE : wait_for_postgres fait `nc -z $SEEDS $DB_PORT` ; vide = boucle infinie
      POSTGRES_SEEDS: {{ cf_pg_host }}
      POSTGRES_USER: {{ cf_pg_admin_user }}   # auto-setup crée temporal/temporal_visibility → superuser requis (cf_app = DSN cf-api uniquement)
      POSTGRES_PWD: {{ postgresql_password }}
      DBNAME: {{ cf_temporal_db_name }}
      VISIBILITY_DBNAME: {{ cf_temporal_visibility_db_name }}
      DEFAULT_NAMESPACE: {{ cf_temporal_namespace }}
      ENABLE_ES: "false"
    networks:
      - {{ cf_backend_network }}           # accès javisi_postgresql + inter-services
    mem_limit: {{ cf_temporal_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      # tctl présent dans l'image auto-setup (vérifié live 2026-07-02 : /usr/local/bin/tctl).
      # PIÈGE : l'entrypoint binde le frontend sur l'IP du conteneur (BIND_ON_IP par défaut
      # = getent hosts $(hostname)), PAS sur 127.0.0.1 → cibler $(hostname -i):7233.
      # `tctl cluster health` → rc 0 + "WorkflowService: SERVING" quand le frontend répond.
      test: ["CMD-SHELL", "tctl --address \"$(hostname -i):7233\" cluster health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  cf-api:
    build:
      context: {{ cf_src_dir }}/apps/api
      dockerfile: Dockerfile
    container_name: cf-api
    restart: unless-stopped
    env_file:
      - {{ cf_config_dir }}/api.env
    networks:
      - {{ cf_backend_network }}           # joindre javisi_postgresql
      - {{ cf_frontend_network }}          # être routé par javisi_caddy
    mem_limit: {{ cf_api_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "python3 -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:8000/health\")'"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s

  cf-conductor:
    build:
      # Contexte = services/ (conductor importe le frère plane-adapter via sys.path)
      context: {{ cf_src_dir }}/services
      dockerfile: conductor/Dockerfile
    container_name: cf-conductor
    restart: unless-stopped
    env_file:
      - {{ cf_config_dir }}/conductor.env
    networks:
      - {{ cf_backend_network }}           # joindre cf-temporal + cf-api (+ egress Plane)
    mem_limit: {{ cf_conductor_mem_limit }}
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    depends_on:
      cf-temporal:
        condition: service_healthy         # healthcheck tctl ci-dessus (audit H7)
      cf-api:
        condition: service_healthy

networks:
  # Réseaux prod pré-existants — jamais créés par ce compose.
  {{ cf_backend_network }}:
    external: true
  {{ cf_frontend_network }}:
    external: true
