    {
      "parameters": {
        "jsCode": "// Validate secret and route to correct action handler\n// Kitsu URL (external): https://{% endraw %}{{ kitsu_subdomain }}{% raw %}.{% endraw %}{{ domain_name }}{% raw %} (for reference only -- internal uses http://kitsu:80)\nconst data = $input.first().json;\nconst expectedSecret = $env.N8N_WEBHOOK_HMAC_SECRET;\n\nif (!expectedSecret) throw new Error('N8N_WEBHOOK_HMAC_SECRET not configured');\n\nconst headers = data.headers || {};\nconst body    = data.body    || data || {};\nconst receivedSecret = headers['x-webhook-secret'] || body.secret || '';\n\nif (receivedSecret !== expectedSecret) throw new Error('Invalid webhook secret');\n\nconst action     = body.action;\nconst content_id = body.content_id;\nconst payload    = body.data || {};\n\nconst VALID_ACTIONS = ['update_task_status', 'create_shot', 'upload_preview', 'add_comment'];\nif (!action || !VALID_ACTIONS.includes(action)) {\n  throw new Error(`Invalid action. Must be one of: ${VALID_ACTIONS.join(', ')}`);\n}\n\nif (!content_id) throw new Error('Missing required field: content_id');\n\nreturn [{ json: { action, content_id, data: payload } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000002",
      "name": "Validate and Route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 380]
    },
    {
      "parameters": {
        "jsCode": "// Authenticate with Kitsu (Zou API) -- re-authenticate every execution (no token caching)\n// Uses internal Docker network URL: http://kitsu:80\nconst { action, content_id, data } = $input.first().json;\n\nif (!$env.KITSU_BOT_EMAIL) throw new Error('KITSU_BOT_EMAIL not configured');\nif (!$env.KITSU_BOT_PASSWORD) throw new Error('KITSU_BOT_PASSWORD not configured');\n\nconst auth = await $http.request({\n  method: 'POST',\n  url: 'http://kitsu:80/api/auth/login',\n  headers: { 'Content-Type': 'application/json' },\n  body: {\n    email: $env.KITSU_BOT_EMAIL,\n    password: $env.KITSU_BOT_PASSWORD\n  }\n});\n\nconst token = auth.access_token;\nif (!token) throw new Error('Kitsu auth failed: no access_token in response');\n\nreturn [{ json: { action, content_id, data, kitsu_token: token } }];"
      },
      "id": "cfks-0001-0000-0000-0000-000000000003",
      "name": "Authenticate with Kitsu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 380]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
