        "method": "GET",
        "url": "=http://javisi_nocodb:8080/api/v2/tables/mx5x4nb739fjld1/records?where=(project,eq,{{ encodeURIComponent($('Parse Phase Data').first().json.project_name) }})&fields=duration_min&limit=1000",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-token",
              "value": "={{ $env.NOCODB_API_TOKEN }}"
