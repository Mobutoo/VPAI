        200
      ],
      "parameters": {
        "method": "POST",
        "url": "http://javisi_nocodb:8080/api/v2/tables/m9spg53b1co2zkq/records",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-token",
              "value": "={{ $env.NOCODB_API_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project: $json.project_name, phase: $json.phase_number, choice: $json.decision_title, reason: $json.decision_rationale, context: $json.decision_category, timestamp: $json.timestamp }) }}",
        "options": {}
      }
    },
    {
