    <script>
        function updateClock() {
            const el = document.getElementById('clock');
            if (el) el.textContent = new Date().toLocaleString('fr-FR', {
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                timeZone: 'Europe/Paris'
            });
        }
        updateClock();
        setInterval(updateClock, 1000);
    </script>
</body>
</html>
