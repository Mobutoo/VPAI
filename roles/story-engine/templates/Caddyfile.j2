# {{ ansible_managed }}
# StoryEngine — Caddy reverse proxy

{
	servers {
		protocols h1 h2
	}
}

{{ story_engine_domain }} {
	# API — forward /api/* to FastAPI (routes already include /api/v1 prefix)
	handle /api/* {
		reverse_proxy api:8000
	}

	# Collab WebSocket — proxy to Hocuspocus (handle_path strips /collab prefix)
	handle_path /collab/* {
		reverse_proxy collab:1234
	}
	handle /collab {
		reverse_proxy collab:1234
	}

	# Health check
	handle /health {
		respond 200
	}

	# Web frontend — catch-all to Next.js
	handle {
		reverse_proxy web:3000
	}
}

vps.ewutelo.cloud {
	# VPS Telehouse — SvelteKit SSR app
	# Added 2026-04-17 (CICD-03 Phase 7, prod fix)
	reverse_proxy vps-telehouse:3000
}

simubot.ewutelo.cloud {
	# SimuBot — added 2026-04-18 (initial scaffold, container deployed in phase 01)
	# Returns 502 until "simubot" container is deployed on simubot_caddy_bridge.
	reverse_proxy simubot:3000
}

mediahall.ewutelo.cloud {
	# NetBox IPAM/DCIM — réseau netbox_mediahall_net connecté au container caddy
	# host: Docker DNS container name dans netbox_mediahall_net
	reverse_proxy netbox-netbox-1:8080
}
