      "id": "nocodb-update-project",
      "name": "NocoDB Update Project",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2230,
        300
      ],
      "parameters": {
        "method": "PATCH",
        "url": "http://javisi_nocodb:8080/api/v2/tables/mvhxrbdyetpoyjb/records",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
