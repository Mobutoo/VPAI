#!/usr/bin/env bash
# secret-run — broker de secrets : exécute une commande avec un secret issu
# du coffre Vaultwarden (via `rbw`) injecté UNIQUEMENT dans l'ENVIRONNEMENT
# du processus enfant — jamais comme argument de commande.
#
# Usage: secret-run <REF> -- <cmd> [args...]
#
# Contrat de sortie (voir test_secret_run.sh — Task 7, plan
# docs/superpowers/plans/2026-07-16-vaultwarden-p0-p1b.md, ligne 81) :
#   exit 2      = refus de politique (ref inconnue de la politique OU
#                 commande non autorisée pour cette ref) — vérifié AVANT
#                 tout appel à rbw, donc AVANT tout accès au coffre.
#   exit != 0/2 = erreur coffre (ref absente du coffre, coffre verrouillé,
#                 etc.) — fail-closed : aucun enfant n'est JAMAIS lancé,
#                 message clair sur stderr mentionnant la ref.
#   sinon       = code de sortie de L'ENFANT, propagé tel quel.
#
# LIMITES ASSUMÉES — à lire avant de faire confiance au filtre stdout/stderr :
#   - Le redacteur est un FILET DE SÉCURITÉ, PAS l'invariant premier.
#     L'invariant premier reste : la valeur du secret n'est JAMAIS un
#     argument de commande (jamais dans argv, jamais dans /proc/<pid>/cmdline
#     d'un process qu'on lance nous-même) — elle ne transite QUE par
#     l'environnement du processus enfant.
#   - Le redacteur remplace la valeur LITTÉRALEMENT (str.replace, pas de
#     regex — évite tout souci de métacaractères dans la valeur du secret),
#     en flux, LIGNE PAR LIGNE (line-buffered, python3 -u). Une valeur de
#     secret COUPÉE ENTRE DEUX CHUNKS/LIGNES (flush au milieu de la valeur)
#     N'EST PAS GARANTIE d'être redactée.
#   - La sortie binaire (non-texte) passe TELLE QUELLE à travers le
#     redacteur (traitement au niveau octets, pas de décodage strict).
#
# Piège bash évité ICI (NOTE-1 du plan) : `export VAR="$(rbw get …)"` masque
# un échec de `rbw` sous `set -e` — car le code de retour d'`export` est 0
# même si la substitution de commande a échoué à l'intérieur, donc `set -e`
# ne peut PAS stopper le script et une valeur vide serait injectée en
# silence. La forme correcte, utilisée ci-dessous, SÉPARE l'assignation
# (`secret_val="$(rbw get …)"` — le code de retour EST testé, `set -e` PEUT
# stopper le script ICI) de l'`export` (ligne séparée, exécutée seulement si
# l'assignation a réussi).

set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
POLICY_FILE="${SECRET_RUN_POLICY:-/etc/secret-run/politique.yml}"
AUDIT_LOG="${SECRET_RUN_AUDIT_LOG:-}"

usage() {
  echo "Usage: secret-run <REF> -- <cmd> [args...]" >&2
}

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------
if [ "$#" -lt 3 ]; then
  usage
  exit 64
fi

REF="$1"
shift
if [ "$1" != "--" ]; then
  usage
  exit 64
fi
shift
CMD="$1"
shift
CMD_ARGS=("$@")
CMD_BASENAME="$(basename -- "$CMD")"

if ! [[ "$REF" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
  echo "secret-run: erreur — ref '$REF' n'est pas un identifiant valide" >&2
  exit 64
fi

# ---------------------------------------------------------------------------
# Audit — n'écrit JAMAIS la valeur du secret, seulement ref/cmd/résultat.
# ---------------------------------------------------------------------------
audit_log() {
  local result="$1"
  local detail="${2:-}"
  [ -n "$AUDIT_LOG" ] || return 0
  local ts
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  printf '{"ts":"%s","ref":"%s","cmd":"%s","result":"%s","detail":"%s"}\n' \
    "$ts" "$REF" "$CMD_BASENAME" "$result" "$detail" >> "$AUDIT_LOG"
}

# ---------------------------------------------------------------------------
# Étape 1 — politique : vérifiée AVANT tout appel à rbw (donc avant tout
# accès au coffre). Format politique (Step 5 du plan) :
#   REF_NAME:
#     commands:
#       - cmd1
#       - cmd2
# ---------------------------------------------------------------------------
POLICY_CHECK_PY='
import sys
import yaml

ref, cmd_basename, policy_path = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(policy_path, "r") as f:
        policy = yaml.safe_load(f) or {}
except (OSError, yaml.YAMLError) as exc:
    print(f"impossible de lire/parser la politique {policy_path}: {exc}", file=sys.stderr)
    sys.exit(5)

entry = policy.get(ref)
if entry is None:
    print(f"ref {ref!r} absente de la politique {policy_path}", file=sys.stderr)
    sys.exit(3)

commands = (entry or {}).get("commands") or []
if cmd_basename not in commands:
    print(f"commande {cmd_basename!r} non autorisee pour la ref {ref!r}", file=sys.stderr)
    sys.exit(4)

sys.exit(0)
'

policy_rc=0
policy_err="$(python3 -c "$POLICY_CHECK_PY" "$REF" "$CMD_BASENAME" "$POLICY_FILE" 2>&1 1>/dev/null)" || policy_rc=$?

if [ "$policy_rc" -ne 0 ]; then
  echo "secret-run: refus de politique — $policy_err" >&2
  audit_log "policy_denied" "$policy_err"
  exit 2
fi

# ---------------------------------------------------------------------------
# Étape 2 — récupération du secret via rbw (coffre). Fail-closed : si `rbw`
# échoue (coffre verrouillé, ref absente du coffre...), `set -e` stoppe le
# script à l'assignation ci-dessous, AVANT tout export et AVANT tout
# lancement d'enfant (voir NOTE-1 en tête de fichier).
# ---------------------------------------------------------------------------
on_vault_error() {
  local rc=$?
  echo "secret-run: erreur coffre — impossible de recuperer le secret pour la ref '$REF' (rbw a retourne le code $rc ; coffre verrouille ou ref absente du coffre)." >&2
  audit_log "vault_error" "rbw exit $rc"
  exit "$rc"
}
trap on_vault_error ERR

secret_val="$(rbw get "$REF")"

trap - ERR
export "${REF}=${secret_val}"

# ---------------------------------------------------------------------------
# Étape 3 — exécution de l'enfant. Le secret est visible UNIQUEMENT dans son
# environnement (jamais dans son argv) : PAS `env VAR=valeur cmd` (la valeur
# finirait dans l'argv du process `env`, visible via /proc/<pid>/cmdline) ;
# PAS `exec` (remplacerait ce process, incompatible avec le filtrage
# stdout/stderr ci-dessous). stdout ET stderr de l'enfant passent chacun par
# une instance du redacteur littéral (python3 -u, line-buffered), en
# parallèle, pour préserver la séparation des deux flux.
# ---------------------------------------------------------------------------
REDACT_PY='
import os
import sys

ref = sys.argv[1]
secret = os.environb.get(ref.encode(), b"")
inp = sys.stdin.buffer
out = sys.stdout.buffer
for line in inp:
    if secret:
        line = line.replace(secret, b"[REDACTED]")
    out.write(line)
    out.flush()
'

exec 3> >(python3 -u -c "$REDACT_PY" "$REF" >&2)
if "$CMD" "${CMD_ARGS[@]}" 1> >(python3 -u -c "$REDACT_PY" "$REF") 2>&3; then
  child_rc=0
else
  child_rc=$?
fi
exec 3>&-
# Attend que les deux redacteurs (process substitution) finissent de
# vidanger/flush avant qu'on ne sorte — évite une sortie tronquée.
wait

unset "${REF}"

audit_log "ok" "child exit $child_rc"
exit "$child_rc"
