# {{ ansible_managed }}
# MeTube environment — video downloader (yt-dlp web UI)

DOWNLOAD_DIR=/downloads
OUTPUT_TEMPLATE={{ metube_output_template }}
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best"}
{% if metube_webhook_url | default('') | length > 0 %}
DOWNLOAD_WEBHOOK_URL={{ metube_webhook_url }}
{% endif %}
