# {{ ansible_managed }}
# Content Factory API (apps/api — FastAPI, app.main:app, port 8000) — variante Sese.
# Postgres prod réutilisé : javisi_postgresql. Mot de passe PARTAGÉ (CLAUDE.md): postgresql_password.
# DSN applicatif = cf_app (audit 2026-07-02 C2 : plus de superuser dans le DSN).
CF_DATABASE_URL=postgresql+psycopg://{{ cf_pg_user }}:{{ postgresql_password }}@{{ cf_pg_host }}:5432/{{ cf_db_name }}
# Bearer requis sur les routes REST (audit C2/A1.2). Source vault: vault_cf_api_token.
CF_API_TOKEN={{ cf_api_token }}
CF_ENV=prod
# Strangler compat (cutover n8n → API) : la façade /compat/* rejoue la validation
# dual-secret v1 (header x-webhook-secret OU body.secret). MÊME secret que côté n8n.
# Absent → /compat/* renvoie 401 (fail-closed). Source vault: vault_n8n_webhook_secret.
N8N_WEBHOOK_HMAC_SECRET={{ n8n_webhook_secret }}
# S0.2 (fin orphelin H3) : cf-api démarre le ContentWorkflow à la création d'une
# Production (app/workflow_starter.py). Gate = présence de CF_TEMPORAL_HOST : la
# poser ICI active l'autostart. cf-api joint cf-temporal sur le réseau backend
# ({{ cf_backend_network }}, même que le conducteur). Best-effort : Temporal
# injoignable ne casse jamais la création (200 conservé). Coût GPU protégé : le
# workflow park à GATE 1 (lock_preprod) tant que S0.3 ne route pas les signaux.
CF_TEMPORAL_HOST={{ cf_temporal_host }}
CF_TEMPORAL_NAMESPACE={{ cf_temporal_namespace }}
CF_TASK_QUEUE={{ cf_task_queue }}
# V-2 découpe : queue des workflows cf-render (POST /references/{id}/detect-scenes
# et /segments, app/workflow_starter.start_render_workflow).
CF_RENDER_TASK_QUEUE={{ cf_render_task_queue }}
# S0.4 — auth Studio (login mot de passe -> JWT HS256, dual-accept avec CF_API_TOKEN).
# Les 2 absents -> /auth/login renvoie 503 (fail-closed), l'API reste utilisable via
# le bearer statique CF_API_TOKEN (conducteur). Source vault.
STUDIO_PASSWORD={{ studio_password }}
STUDIO_JWT_SECRET={{ studio_jwt_secret }}
# CORS : le Studio (https://{{ caddy_studio_domain }}) est une origine distincte de
# cf-api -> autoriser le préflight + Access-Control-Allow-Origin. CSV multi-origines.
CF_CORS_ORIGINS=https://{{ caddy_studio_domain }}
# S2 — persistance de la sortie vidéo : répertoire du volume Docker `cf_media`
# (docker-compose.yml.j2 : `cf_media:/media` sur le service cf-api). Le worker GPU
# uploade sur POST /takes/{id}/representations, cf-api écrit sous CF_MEDIA_DIR/{take_id}/.
CF_MEDIA_DIR=/media
# V5-B — base publique des URLs média query-token embarquées dans les
# MontageProps (les <video src> Remotion ne passent pas de header ; Chromium
# waza charge via le vhost public token-gated).
CF_MEDIA_PUBLIC_BASE=https://{{ cf_subdomain | default('cf') }}.{{ domain_name }}
# V-4 — miroir du gate vision (la route POST /shots/{id}/describe rend 503 si off).
CF_VISION_LIVE={{ cf_vision_live }}
# T5 — gate route nl-edit (503 si off), miroir CF_VISION_LIVE.
CF_LLM_LIVE={{ cf_llm_live }}
# Bloc 3 — gate gap-analysis (POST /productions/{id}/gap-analysis, app/gaps.py).
# OFF => suggestions [] déterministes, zéro réseau. ON => appel proxy LiteLLM
# (modèle claude-haiku par défaut, CF_GAP_MODEL app-side ; budget cap $5/j côté proxy).
CF_GAP_LIVE={{ cf_gap_live }}
LITELLM_API_KEY={{ cf_litellm_api_key }}
LITELLM_BASE_URL={{ cf_litellm_base_url }}
