      ],
      "webhookId": "vri00001-5678-4000-8000-vrefremixin1"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst payload = raw.body || raw;\nconst secret = $env.N8N_WEBHOOK_SECRET || '';\n\nif (secret && payload.secret !== secret) {\n  throw new Error('Invalid webhook secret');\n}\n\nconst required = ['url', 'instructions'];\nfor (const f of required) {\n  if (!payload[f]) throw new Error(`Missing required field: ${f}`);\n}\n\nconst sourceUrl = String(payload.url).trim();\nconst instructions = String(payload.instructions).trim();\nconst format = payload.format || 'story';\nconst title = (payload.title || instructions).slice(0, 80);\n\nconst now = new Date();\nconst slug = 'remix-' + now.toISOString().slice(0,10).replace(/-/g,'') + '-' + Math.random().toString(36).slice(2,7);\n\nconst metubeUrl = $env.METUBE_URL || 'http://javisi_metube:8081';\nconst vrefUrl   = $env.VREF_URL   || 'http://javisi_vref_mock:8082';\n\nreturn [{ json: {\n  source_url: sourceUrl,\n  instructions,\n  format,\n  title,\n  slug,\n  metube_url: metubeUrl,\n  vref_url:   vrefUrl,\n  metube_payload: {\n    url: sourceUrl,\n    quality: '720',\n    format: 'mp4'\n  }\n}}];"
      },
      "id": "vri-0001-0000-4000-8000-000000000002",
      "name": "Validate & Prepare",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.metube_url + '/add' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
