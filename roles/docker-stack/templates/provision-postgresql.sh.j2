#!/bin/bash
# {{ ansible_managed }}
# PostgreSQL provisioning script — idempotent
# Creates databases and users if they don't exist

set -euo pipefail

CONTAINER="{{ project_name }}_postgresql"
export PGPASSWORD='{{ postgresql_password }}'

{% for db in postgresql_databases %}
# === Database: {{ db.name }} ===
DB_EXISTS=$(docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -tAc \
  "SELECT 1 FROM pg_database WHERE datname='{{ db.name }}'") || DB_EXISTS=""
if [ "$DB_EXISTS" != "1" ]; then
  echo "Creating database {{ db.name }}..."
  docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -c \
    "CREATE DATABASE {{ db.name }};"
fi

USER_EXISTS=$(docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -tAc \
  "SELECT 1 FROM pg_roles WHERE rolname='{{ db.user }}'") || USER_EXISTS=""
if [ "$USER_EXISTS" != "1" ]; then
  echo "Creating user {{ db.user }}..."
  docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -c \
    "CREATE USER {{ db.user }} WITH ENCRYPTED PASSWORD '{{ postgresql_password }}';"
fi

docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -c \
  "GRANT ALL PRIVILEGES ON DATABASE {{ db.name }} TO {{ db.user }};"
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -c \
  "ALTER DATABASE {{ db.name }} OWNER TO {{ db.user }};"
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -d {{ db.name }} -c \
  "GRANT ALL ON SCHEMA public TO {{ db.user }};"
{% for ext in db.extensions %}
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U postgres -d {{ db.name }} -c \
  "CREATE EXTENSION IF NOT EXISTS \"{{ ext }}\";"
{% endfor %}

{% endfor %}

# === Model Scores table (in n8n database) ===
# Used by the AI Model Scoring n8n workflow — PostgreSQL as source of truth
echo "Provisioning model_scores table in n8n database..."
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U n8n -d n8n -c "
CREATE TABLE IF NOT EXISTS model_scores (
  model       TEXT PRIMARY KEY,
  total_calls     INTEGER DEFAULT 0,
  successful_calls INTEGER DEFAULT 0,
  failed_calls    INTEGER DEFAULT 0,
  total_tokens    BIGINT DEFAULT 0,
  total_cost      DOUBLE PRECISION DEFAULT 0,
  total_latency_ms DOUBLE PRECISION DEFAULT 0,
  likes           INTEGER DEFAULT 0,
  dislikes        INTEGER DEFAULT 0,
  score           INTEGER DEFAULT 50,
  avg_cost_per_call DOUBLE PRECISION DEFAULT 0,
  avg_latency_ms  DOUBLE PRECISION DEFAULT 0,
  source          TEXT DEFAULT 'unknown',
  first_seen      TIMESTAMPTZ DEFAULT NOW(),
  last_updated    TIMESTAMPTZ DEFAULT NOW()
);
"

# === Memory runs table (in n8n database) ===
# Used by the memory-run-report-ingest and memory-healthcheck workflows
# to persist worker run reports from Waza llamaindex-memory-worker.
echo "Provisioning memory_runs table in n8n database..."
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U n8n -d n8n -c "
CREATE TABLE IF NOT EXISTS memory_runs (
  id                    BIGSERIAL PRIMARY KEY,
  run_id                TEXT NOT NULL,
  received_at           TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  report_schema_version TEXT,
  worker_version        TEXT,
  host_origin           TEXT,
  repo                  JSONB,
  mode                  TEXT,
  collection_name       TEXT,
  embedding_model       TEXT,
  started_at            TIMESTAMPTZ,
  duration_sec          NUMERIC,
  attempted_files       INTEGER,
  indexed_files         INTEGER,
  indexed_chunks        INTEGER,
  indexed_points        INTEGER,
  skipped_files         INTEGER,
  errors                JSONB,
  spool_size            INTEGER,
  qdrant_reachable      BOOLEAN,
  exit_code             INTEGER
);
-- loadavg_1min added after the initial v0.6 schema. The ALTER IF NOT EXISTS
-- keeps the provisioning script idempotent on redeploys.
ALTER TABLE memory_runs ADD COLUMN IF NOT EXISTS loadavg_1min NUMERIC;
DELETE FROM memory_runs a
USING memory_runs b
WHERE a.run_id = b.run_id
  AND a.id < b.id;
CREATE UNIQUE INDEX IF NOT EXISTS idx_memory_runs_run_id_unique
  ON memory_runs (run_id);
CREATE INDEX IF NOT EXISTS idx_memory_runs_received_at
  ON memory_runs (received_at DESC);
CREATE INDEX IF NOT EXISTS idx_memory_runs_host_origin
  ON memory_runs (host_origin);
CREATE INDEX IF NOT EXISTS idx_memory_runs_exit_code
  ON memory_runs (exit_code);
"

# === Memory worker state table (in n8n database) ===
# Single row per host_origin reflecting live worker state. Updated by the
# memory-run-report-ingest workflow on both "start" events (worker begins a
# run) and final reports (worker finished). Consumed by the memory-telegram-bot
# workflow to show live state in /memory_status.
echo "Provisioning memory_worker_state table in n8n database..."
docker exec -e PGPASSWORD="${PGPASSWORD}" "${CONTAINER}" psql -U n8n -d n8n -c "
CREATE TABLE IF NOT EXISTS memory_worker_state (
  host_origin       TEXT PRIMARY KEY,
  state             TEXT,
  started_at        TIMESTAMPTZ,
  mode              TEXT,
  repos_target      JSONB,
  last_run_id       TEXT,
  last_exit_code    INTEGER,
  last_completed_at TIMESTAMPTZ,
  updated_at        TIMESTAMPTZ NOT NULL DEFAULT NOW()
);
"

echo "PostgreSQL provisioning complete."
