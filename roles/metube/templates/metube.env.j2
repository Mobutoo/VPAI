# {{ ansible_managed }}
# MeTube environment — video downloader (yt-dlp web UI)

DOWNLOAD_DIR=/downloads
OUTPUT_TEMPLATE={{ metube_output_template }}
YTDL_OPTIONS={"format":"bestvideo[height<=?{{ metube_max_quality }}]+bestaudio/best"}
{% if videoref_port | default('') | string | length > 0 %}
# VideoRef Engine webhook (same Docker network — auto-trigger analysis on download)
DOWNLOAD_WEBHOOK_URL=http://workstation_videoref:{{ videoref_port }}/api/webhook/metube
{% elif metube_webhook_url | default('') | length > 0 %}
# n8n webhook (VPS via mesh VPN)
DOWNLOAD_WEBHOOK_URL={{ metube_webhook_url }}
{% endif %}
