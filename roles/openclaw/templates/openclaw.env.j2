# {{ ansible_managed }}
# OpenClaw Gateway environment
# Architecture: OpenClaw -> LiteLLM (custom-litellm/*) OR OpenAI direct (openai/*)
# Provider "openai" uses OPENAI_API_KEY directly (bypass LiteLLM for resilience)

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN={{ openclaw_gateway_token }}

# Config and state paths — MUST match host paths for Docker-in-Docker sandbox mounts.
# OpenClaw spawns sandbox containers via Docker socket (DooD). The sandbox bind-mount
# paths use OPENCLAW_STATE_DIR as base. Docker daemon resolves these on the HOST,
# so container paths and host paths MUST be identical.
OPENCLAW_STATE_DIR={{ openclaw_system_dir }}
OPENCLAW_CONFIG_PATH={{ openclaw_system_dir }}/openclaw.json
HOME=/home/node

# LiteLLM proxy key (used by custom-litellm provider in openclaw.json)
LITELLM_API_KEY={{ litellm_master_key }}

# OpenAI direct key (used by openai provider in openclaw.json — bypass LiteLLM)
OPENAI_API_KEY={{ openai_api_key }}

# OpenRouter key (used by failover/announce mechanism in OpenClaw v2026.2.22)
{% if openrouter_api_key | default('') | length > 0 %}
OPENROUTER_API_KEY={{ openrouter_api_key }}
{% endif %}

# Anthropic key (used by failover/announce mechanism)
{% if anthropic_api_key | default('') | length > 0 %}
ANTHROPIC_API_KEY={{ anthropic_api_key }}
{% endif %}

# Telegram Bot (dedicated OpenClaw channel)
{% if telegram_openclaw_bot_token | default('') | length > 0 %}
TELEGRAM_BOT_TOKEN={{ telegram_openclaw_bot_token }}
{% endif %}

# n8n integration (webhook delegation)
{% if openclaw_n8n_integration | default(false) %}
N8N_WEBHOOK_SECRET={{ n8n_webhook_secret }}
N8N_WEBHOOK_BASE_URL={{ n8n_webhook_base_url }}
{% endif %}

# Qdrant (RAG content search via skill)
QDRANT_API_KEY={{ qdrant_api_key }}
QDRANT_RAG_COLLECTION={{ qdrant_rag_collection }}

# Brave Search API (web_search tool for explorer agent)
{% if brave_search_api_key | default('') | length > 0 %}
BRAVE_API_KEY={{ brave_search_api_key }}
{% endif %}

# Node.js memory — prevent OOM crash (default heap limit is ~512MB)
NODE_OPTIONS=--max-old-space-size={{ openclaw_node_heap_mb | default(768) }}

# Sandbox browser: disable Chrome sandbox inside Docker containers (v2026.3.1 #29879)
OPENCLAW_BROWSER_NO_SANDBOX=1

# NocoDB integration (pipeline production IA manga)
NOCODB_BASE_URL=http://nocodb:8080
NOCODB_API_TOKEN={{ nocodb_api_token }}

# Plane API — agent tokens for workspace Ewutelo (Phase 2)
{% for agent in plane_agent_names | default(['concierge','imhotep','thot','basquiat','r2d2','piccolo','cfo','maintainer','hermes','marketer']) %}
PLANE_TOKEN_{{ agent | upper }}={{ vault_plane_agent_tokens[agent] | default('PROVISION_PENDING') }}
{% endfor %}
PLANE_WORKSPACE_SLUG={{ plane_workspace_slug | default('ewutelo') }}
PLANE_API_URL=http://plane-api:8000

# Timezone
TZ={{ timezone }}
