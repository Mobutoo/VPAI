# Dockerfile-Plugins — Image NetBox custom avec plugins (généré par Ansible)
# Base: {{ netbox_image }} (officielle pinnée)
FROM {{ netbox_image }}

USER root

# Bootstrap pip via get-pip.py into the venv (image ships without pip/ensurepip).
# NOTE: do NOT purge curl — launch-netbox.sh requires it to configure nginx-unit.
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl && \
    curl -sSL https://bootstrap.pypa.io/get-pip.py | /opt/netbox/venv/bin/python3 && \
    /opt/netbox/venv/bin/python3 -m pip install --no-cache-dir \
        netbox-topology-views=={{ netbox_topology_views_version }} && \
    rm -rf /var/lib/apt/lists/*

USER unit
