    {
      "parameters": {
        "jsCode": "const remix = $input.first().json;\nconst ctx = $('Build Remix Payload').first().json;\n\nconst remixed_prompt = remix.remixed_prompt || remix.suggested_prompt || ctx.source_prompt;\n\nconst brief = {\n  objective: `Remix: ${ctx.instructions}`,\n  source_url: ctx.source_url,\n  source_prompt: ctx.source_prompt,\n  remixed_prompt,\n  style: remix.style || '',\n  mood: remix.mood || '',\n  submitted_at: new Date().toISOString()\n};\n\nreturn [{ json: {\n  ...ctx,\n  remix,\n  remixed_prompt,\n  brief,\n  nocodb_body: {\n    title: ctx.title,\n    format: ctx.format,\n    status: 'intake',\n    brief\n  }\n}}];"
      },
