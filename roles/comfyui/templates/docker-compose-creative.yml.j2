# {{ ansible_managed }}
# docker-compose-creative.yml — Creative Studio (RPi 5)
# ComfyUI (image gen) + Remotion (video render)
# Shared assets volume for cross-service file exchange

services:
  comfyui:
    image: comfyui-local:{{ comfyui_version }}
    container_name: workstation_comfyui
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETGID
      - SETUID
{% if comfyui_fal_key | default('') | length > 0 %}
    environment:
      FAL_KEY: "{{ comfyui_fal_key }}"
{% endif %}
    volumes:
      - {{ comfyui_data_dir }}/models:/app/models
      - {{ comfyui_data_dir }}/output:/app/output
      - {{ comfyui_data_dir }}/input:/app/input
      - {{ comfyui_data_dir }}/custom_nodes:/app/custom_nodes
      - {{ creative_assets_dir }}:/app/creative-assets
    ports:
      - "127.0.0.1:{{ comfyui_port }}:8188"
    networks:
      - creative
    deploy:
      resources:
        limits:
          memory: {{ comfyui_memory_limit }}
          cpus: "{{ comfyui_cpu_limit }}"
        reservations:
          memory: {{ comfyui_memory_reservation }}
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8188/system_stats', timeout=8)\" || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s

{% if remotion_port is defined %}
  remotion:
    image: remotion-local:{{ remotion_version }}
    container_name: workstation_remotion
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETGID
      - SETUID
    environment:
      PORT: "{{ remotion_port }}"
      REMOTION_API_TOKEN: "{{ vault_remotion_api_token | default('') }}"
      REMOTION_PUBLIC_URL: "https://{{ remotion_subdomain }}.{{ domain_name }}"
      NODE_ENV: "production"
    volumes:
      - {{ remotion_data_dir }}/renders:/app/renders
      - {{ creative_assets_dir }}:/app/creative-assets:ro
    ports:
      - "127.0.0.1:{{ remotion_port }}:{{ remotion_port }}"
    networks:
      - creative
    deploy:
      resources:
        limits:
          memory: {{ remotion_memory_limit }}
          cpus: "{{ remotion_cpu_limit }}"
        reservations:
          memory: {{ remotion_memory_reservation }}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{ remotion_port }}/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
{% endif %}

{% if metube_image | default('') | length > 0 %}
  metube:
    image: {{ metube_image }}
    container_name: workstation_metube
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    env_file:
      - {{ metube_install_dir }}/metube.env
    volumes:
      - {{ metube_download_dir }}:/downloads
      - {{ creative_assets_dir }}:/app/creative-assets
    ports:
      - "127.0.0.1:{{ metube_port }}:8081"
    networks:
      - creative
    deploy:
      resources:
        limits:
          memory: {{ metube_memory_limit }}
          cpus: "{{ metube_cpu_limit }}"
        reservations:
          memory: {{ metube_memory_reservation }}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8081/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{% endif %}

{% if videoref_image | default('') | length > 0 %}
  videoref-engine:
    image: {{ videoref_image }}
    container_name: workstation_videoref
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    env_file:
      - {{ videoref_install_dir }}/videoref.env
    volumes:
      - {{ videoref_watch_dir }}:/watch:ro
      - {{ videoref_output_dir }}:/analyzed
      - {{ videoref_comfyui_workflows_dir }}:/comfyui-workflows
      - {{ creative_assets_dir }}:/app/creative-assets
    ports:
      - "127.0.0.1:{{ videoref_port }}:8082"
    networks:
      - creative
    deploy:
      resources:
        limits:
          memory: {{ videoref_memory_limit }}
          cpus: "{{ videoref_cpu_limit }}"
        reservations:
          memory: {{ videoref_memory_reservation }}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8082/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
{% endif %}

networks:
  creative:
    name: workstation_creative
    driver: bridge
