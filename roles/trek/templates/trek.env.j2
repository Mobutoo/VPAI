# {{ ansible_managed }}
# TREK Environment — managed by Ansible
# Public travel planner — native auth, isolated from the AI backend.

NODE_ENV=production
PORT={{ trek_web_port }}
TZ={{ timezone | default('Europe/Paris') }}
LOG_LEVEL=info
DEFAULT_LANGUAGE=fr

# Public URL & reverse proxy (Caddy terminates TLS — exactly 1 proxy hop)
APP_URL=https://{{ caddy_trek_domain }}
ALLOWED_ORIGINS=https://{{ caddy_trek_domain }}
FORCE_HTTPS=true
HSTS_INCLUDE_SUBDOMAINS=false
TRUST_PROXY=1
COOKIE_SECURE=true

# Security: block SSRF toward internal RFC-1918 services (AI backend, same host)
ALLOW_INTERNAL_NETWORK=false

# Data encryption at rest — generated ONCE, NEVER rotate (rotating orphans all
# encrypted data). Stored in Ansible Vault (vault_trek_encryption_key).
ENCRYPTION_KEY={{ vault_trek_encryption_key }}

# First admin — applies only on first boot, before any user exists.
ADMIN_EMAIL={{ trek_admin_email }}
ADMIN_PASSWORD={{ vault_trek_admin_password }}

# Built-in TREK MCP server — rate limits (auth-gated per user)
MCP_RATE_LIMIT=300
MCP_MAX_SESSION_PER_USER=20
